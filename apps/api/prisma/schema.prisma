  // Phase 129 — equity grants (RSU/NSO/ISO/etc.).
  equityGrants            EquityGrant[]
  // Phase 130 — volunteer time off entries.
  volunteerEntries        VolunteerEntry[]

  @@index([deletedAt])
  @@index([managerId])
  @@index([departmentId])
  @@index([costCenterId])
  @@index([jobProfileId])
}

