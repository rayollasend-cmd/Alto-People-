  successionCandidacies   SuccessionCandidate[]
  // Phase 116 — probation history (one ACTIVE at a time).
  probationPeriods        ProbationPeriod[]
  // Phase 118 — formal disciplinary actions.
  disciplinaryActions     DisciplinaryAction[]
  // Phase 119 — separations + exit interviews.
  separations             Separation[]
  // Phase 120 — internal mobility applications.
  internalApplications    InternalJobApplication[]
  // Phase 121 — vaccination + medical records.
  vaccinationRecords      VaccinationRecord[]
  // Phase 122 — per-associate legal agreements (NDA, non-compete, etc.).
  agreements              Agreement[]
  // Phase 123 — HR cases filed by this associate + comments authored.
  hrCasesFiled            HrCase[]
  hrCaseCommentsAuthored  HrCaseComment[]          @relation("HrCaseCommentAssociateAuthor")
  // Phase 124 — KB feedback votes.
