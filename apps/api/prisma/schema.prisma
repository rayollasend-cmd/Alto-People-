model TimeEntry {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId     String          @db.Uuid
  // Denormalized clientId so HR can scope/filter by client without joining.
  // Captured from the Associate's currently-assigned client at clock-in.
  clientId        String?         @db.Uuid
  // Optional Job for cost-coding. Null means generic / undifferentiated time.
  jobId           String?         @db.Uuid
  clockInAt       DateTime        @db.Timestamptz(6)
  clockOutAt      DateTime?       @db.Timestamptz(6)
  // GPS coords captured from the associate's device at each transition.
  // Used for geofence audit; nullable so the partial-unique still works
  // and so older entries (pre-geofence) aren't broken.
  clockInLat      Decimal?        @db.Decimal(10, 7)
  clockInLng      Decimal?        @db.Decimal(10, 7)
  clockOutLat     Decimal?        @db.Decimal(10, 7)
  clockOutLng     Decimal?        @db.Decimal(10, 7)
  // Snapshotted pay rate at clock-in time for payroll repeatability.
  payRate         Decimal?        @db.Decimal(8, 2)
  status          TimeEntryStatus @default(ACTIVE)
  notes           String?
  // Tags surfaced in the HR queue: NO_BREAK, OVERTIME_UNAPPROVED,
  // GEOFENCE_VIOLATION, FORGOT_CLOCKOUT, MEAL_BREAK_TOO_SHORT, etc.
  // Computed at clock-out and re-computed on edit.
  anomalies       Json?
  rejectionReason String?
  approvedById    String?         @db.Uuid
  approvedAt      DateTime?       @db.Timestamptz(6)
  // Phase 86 — optional project tag for cost coding.
  projectId       String?         @db.Uuid

  associate            Associate            @relation(fields: [associateId], references: [id], onDelete: Cascade)
  approvedBy           User?                @relation("TimeApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  job                  Job?                 @relation(fields: [jobId], references: [id], onDelete: SetNull)
  project              Project?             @relation(fields: [projectId], references: [id], onDelete: SetNull)
  breaks               BreakEntry[]
  timeOffLedgerEntries TimeOffLedgerEntry[]
  // Phase 99 — kiosk punches that opened/closed this entry.
  kioskPunches         KioskPunch[]
  createdAt            DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @db.Timestamptz(6)

  // At most one ACTIVE row per associate at any time. Postgres treats this
  // as a partial unique via the where clause below.
  @@index([associateId, clockInAt])
  @@index([clientId, status])
  @@index([status])
  @@index([jobId])
  @@index([projectId])
}

model Shift {
  id                  String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String                          @db.Uuid
  position            String
  startsAt            DateTime                        @db.Timestamptz(6)
  endsAt              DateTime                        @db.Timestamptz(6)
  location            String?
  // What the client is billed (revenue side).
  hourlyRate          Decimal?                        @db.Decimal(8, 2)
  // What the associate is paid (cost side). null = use Job.payRate or default.
  payRate             Decimal?                        @db.Decimal(8, 2)
  status              ShiftStatus                     @default(DRAFT)
  notes               String?
  assignedAssociateId String?                         @db.Uuid
  assignedAt          DateTime?                       @db.Timestamptz(6)
  createdById         String?                         @db.Uuid
  cancelledAt         DateTime?                       @db.Timestamptz(6)
  cancellationReason  String?
  // Phase 25 — stamped the first time the shift transitions out of DRAFT
  // (= "schedule was published"). Combined with startsAt, this is the
  // notice window every fair-workweek law audits against.
  publishedAt         DateTime?                       @db.Timestamptz(6)
  // Documented justification when a shift in a fair-workweek state was
  // published inside the 14-day notice window (mutual agreement,
  // emergency call-out cover, etc.). Required by the API for those cases.
  lateNoticeReason    String?
  client              Client                          @relation(fields: [clientId], references: [id], onDelete: Restrict)
  assignedAssociate   Associate?                      @relation(fields: [assignedAssociateId], references: [id], onDelete: SetNull)
  createdBy           User?                           @relation("ShiftCreator", fields: [createdById], references: [id], onDelete: SetNull)
  swapRequests        ShiftSwapRequest[]
  // Phase 85 — qualification gates + open-shift claims.
  qualReqs            ShiftQualificationRequirement[]
  claims              OpenShiftClaim[]
  createdAt           DateTime                        @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime                        @updatedAt @db.Timestamptz(6)

  @@index([clientId, startsAt])
  @@index([assignedAssociateId, startsAt])
  @@index([status, startsAt])
}

// Phase 51 — reusable shift template ("Friday closer", "weekend
// opener"). Apply-template stamps a DRAFT shift onto the configured
// dayOfWeek of a target week. Times are minute-of-day (0..1439) so
// templates are timezone-agnostic — they instantiate against the
// browser-local week start.
model ShiftTemplate {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // null clientId = global template usable across every client.
  clientId    String?   @db.Uuid
  name        String
  position    String
  dayOfWeek   Int // 0 = Sunday … 6 = Saturday (matches JS Date.getDay).
  startMinute Int // minutes from local midnight, 0..1439.
  endMinute   Int // minutes from local midnight, 0..1439. May be < startMinute for overnight.
  location    String?
  hourlyRate  Decimal?  @db.Decimal(8, 2)
  payRate     Decimal?  @db.Decimal(8, 2)
  notes       String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)
  client      Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, dayOfWeek])
  @@index([deletedAt])
}

model Job {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String      @db.Uuid
  name        String
  // Default rates if a Shift doesn't override. Bill = revenue, pay = cost.
  billRate    Decimal?    @db.Decimal(8, 2)
  payRate     Decimal?    @db.Decimal(8, 2)
  isActive    Boolean     @default(true)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?   @db.Timestamptz(6)

  @@unique([clientId, name])
  @@index([clientId, isActive])
}

model BreakEntry {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timeEntryId String    @db.Uuid
  type        BreakType
  startedAt   DateTime  @db.Timestamptz(6)
  endedAt     DateTime? @db.Timestamptz(6)
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([timeEntryId])
}

// Phase 26 — time-off categories. Sick is the only one accruing
// automatically today (driven by StateLaborPolicy.paidSickLeaveAccrualPerHour
// when a TimeEntry is approved). VACATION/PTO/etc. exist in the enum so the
// later request-flow phase doesn't need a schema migration.
enum TimeOffCategory {
  SICK
  VACATION
  PTO
  BEREAVEMENT
  JURY_DUTY
  OTHER
}

// Source of a ledger entry. ACCRUAL = automatic from worked time.
// USE = consumed by an approved time-off request. ADJUSTMENT = HR
// manually credited or debited (carryover at year boundary, dispute fix,
// etc.). PAYOUT = associate cashed out at termination.
enum TimeOffLedgerReason {
  ACCRUAL
  USE
  ADJUSTMENT
  PAYOUT
  // Phase 43 — at the annual reset boundary, balance above
  // carryoverMaxMinutes is forfeited. Negative deltaMinutes.
  CARRYOVER_FORFEIT
  // Phase 43 — annual lump-sum grant for entitlements like VACATION /
  // PTO. Positive deltaMinutes.
  ANNUAL_GRANT
}

// Phase 43 — annual entitlements for VACATION / PTO / etc. SICK accrual
// is per-worked-hour (Phase 26) and doesn't need this model. The reset
// pattern: at the start of each entitlement year, current balance is
// capped at carryoverMaxMinutes, then annualMinutes is granted on top.
// `lastGrantedAt` makes the grant idempotent — running the helper twice
// in the same window is a no-op. `policyAnchorDate` lets HR pick the
// reset month (e.g. Jan 1 vs hire-anniversary).
model TimeOffEntitlement {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId         String          @db.Uuid
  category            TimeOffCategory
  annualMinutes       Int
  carryoverMaxMinutes Int             @default(0)
  // Anchor for the annual reset. Resets happen on the same MM-DD each
  // year. Default = Jan 1.
  policyAnchorDate    DateTime        @default(dbgenerated("DATE '2000-01-01'")) @db.Date
  lastGrantedAt       DateTime?       @db.Date
  createdAt           DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime        @updatedAt @db.Timestamptz(6)
  associate           Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([associateId, category])
  @@index([associateId])
}

model TimeOffBalance {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String          @db.Uuid
  category       TimeOffCategory
  // Stored in MINUTES so we don't lose precision on fractional accrual
  // (CA: 1hr per 30hrs = 2 min per worked hour). Convert to hours at the
  // edge for display.
  balanceMinutes Int             @default(0)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  associate      Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([associateId, category])
  @@index([associateId])
}

model TimeOffLedgerEntry {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId       String              @db.Uuid
  category          TimeOffCategory
  reason            TimeOffLedgerReason
  // Signed: +N for accrual/credit, -N for use/payout.
  deltaMinutes      Int
  // Optional foreign keys so we can audit-trail back to the source.
  // sourceTimeEntryId is the worked entry that drove an ACCRUAL row.
  sourceTimeEntryId String?             @db.Uuid
  // Phase 30 — the request that drove a USE row. One USE entry per request.
  sourceRequestId   String?             @unique @db.Uuid
  sourceUserId      String?             @db.Uuid
  notes             String?
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  associate         Associate           @relation(fields: [associateId], references: [id], onDelete: Cascade)
  sourceTimeEntry   TimeEntry?          @relation(fields: [sourceTimeEntryId], references: [id], onDelete: SetNull)
  sourceRequest     TimeOffRequest?     @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)
  sourceUser        User?               @relation(fields: [sourceUserId], references: [id], onDelete: SetNull)

  // Idempotency guard for the accrual hook: one accrual row per (entry,
  // category). If the approve handler runs twice we no-op.
  @@unique([sourceTimeEntryId, category, reason], name: "uniq_accrual_per_entry")
  @@index([associateId, createdAt])
}

// Phase 30 — associate-submitted time-off request and its approval state.
// Approval is the single point that debits the balance ledger; denial /
// cancellation never touches the ledger. The unique sourceRequestId on
// TimeOffLedgerEntry guarantees at-most-one USE entry per request even if
// the approve handler is retried.
enum TimeOffRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model TimeOffRequest {
  id               String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId      String               @db.Uuid
  category         TimeOffCategory
  // Inclusive day range. We store dates (not timestamps) because requests
  // are scheduled at day granularity; the UI picks days, not minutes.
  startDate        DateTime             @db.Date
  endDate          DateTime             @db.Date
  // Hours requested in MINUTES so the unit matches the ledger and balance.
  // We store minutes (not days) because part-days are valid (a half-day off
  // = 240 min for an 8h schedule) and we'd lose precision converting twice.
  requestedMinutes Int
  reason           String?
  status           TimeOffRequestStatus @default(PENDING)
  reviewerUserId   String?              @db.Uuid
  reviewerNote     String?
  decidedAt        DateTime?            @db.Timestamptz(6)
  cancelledAt      DateTime?            @db.Timestamptz(6)
  createdAt        DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @db.Timestamptz(6)

  associate   Associate           @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewer    User?               @relation("TimeOffReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  ledgerEntry TimeOffLedgerEntry?

  @@index([associateId, status])
  @@index([status, createdAt])
}

model AssociateAvailability {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId String    @db.Uuid
  // 0 = Sunday … 6 = Saturday
  dayOfWeek   Int
  // Minutes since midnight: 480 = 08:00, 1080 = 18:00.
  startMinute Int
  endMinute   Int
  associate   Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@index([associateId, dayOfWeek])
}

model ShiftSwapRequest {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId                 String          @db.Uuid
  requesterAssociateId    String          @db.Uuid
  // Counterparty associate the requester proposes the swap to. They must
  // accept before HR/Ops sees it for final approval.
  counterpartyAssociateId String          @db.Uuid
  status                  ShiftSwapStatus @default(PENDING_PEER)
  note                    String?
  decidedById             String?         @db.Uuid
  decidedAt               DateTime?       @db.Timestamptz(6)
  shift                   Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester               Associate       @relation("SwapRequester", fields: [requesterAssociateId], references: [id], onDelete: Cascade)
  counterparty            Associate       @relation("SwapCounterparty", fields: [counterpartyAssociateId], references: [id], onDelete: Cascade)
  createdAt               DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime        @updatedAt @db.Timestamptz(6)

  @@index([shiftId])
  @@index([counterpartyAssociateId, status])
  @@index([requesterAssociateId, status])
}

model PayrollRun {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // clientId is nullable so a run can span all clients (Alto-internal payroll).
  clientId              String?                @db.Uuid
  periodStart           DateTime               @db.Date
  periodEnd             DateTime               @db.Date
  status                PayrollRunStatus       @default(DRAFT)
  totalGross            Decimal                @default(0) @db.Decimal(12, 2)
  totalTax              Decimal                @default(0) @db.Decimal(12, 2)
  totalNet              Decimal                @default(0) @db.Decimal(12, 2)
  // Phase 18 — employer-side total (FICA match + Medicare match + FUTA + SUTA)
  // is the company's true cost on top of totalGross. Used in finance reports.
  totalEmployerTax      Decimal                @default(0) @db.Decimal(12, 2)
  notes                 String?
  createdById           String?                @db.Uuid
  finalizedAt           DateTime?              @db.Timestamptz(6)
  disbursedAt           DateTime?              @db.Timestamptz(6)
  cancelledAt           DateTime?              @db.Timestamptz(6)
  // Phase 44 — QuickBooks Online journal-entry sync. Set to the QBO
  // JournalEntry.Id on first successful sync; qboSyncError carries the
  // last failure reason so HR can retry from the UI.
  qboJournalEntryId     String?                @db.VarChar(64)
  qboSyncedAt           DateTime?              @db.Timestamptz(6)
  qboSyncError          String?
  client                Client?                @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy             User?                  @relation("PayrollRunCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items                 PayrollItem[]
  // Phase 91 — garnishment deductions sourced from this run.
  garnishmentDeductions GarnishmentDeduction[]
  // Phase 97 — reimbursements paid in this run.
  reimbursementsPaid    Reimbursement[]
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)

  @@index([clientId, periodStart])
  @@index([status])
}

model PayrollItem {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId       String            @db.Uuid
  associateId        String            @db.Uuid
  // Snapshot of inputs at the time of aggregation. Source TimeEntries /
  // Shifts can change later (e.g. a bug-fix amendment), but the paystub
  // record is immutable.
  hoursWorked        Decimal           @db.Decimal(8, 2)
  hourlyRate         Decimal           @db.Decimal(8, 2)
  grossPay           Decimal           @db.Decimal(12, 2)
  // Phase 18 employee-side tax breakdown. federalWithholding is now FIT
  // alone — it used to absorb the placeholder flat tax. fica =
  // 6.2% Social Security (capped at SS wage base), medicare = 1.45% +
  // 0.9% surcharge over $200k YTD, stateWithholding = per-state SIT.
  federalWithholding Decimal           @db.Decimal(12, 2)
  fica               Decimal           @default(0) @db.Decimal(12, 2)
  medicare           Decimal           @default(0) @db.Decimal(12, 2)
  stateWithholding   Decimal           @default(0) @db.Decimal(12, 2)
  // Phase 18 employer-side. The company owes these on top of gross.
  employerFica       Decimal           @default(0) @db.Decimal(12, 2)
  employerMedicare   Decimal           @default(0) @db.Decimal(12, 2)
  employerFuta       Decimal           @default(0) @db.Decimal(12, 2)
  employerSuta       Decimal           @default(0) @db.Decimal(12, 2)
  // YTD snapshots at the moment this paystub was computed. Required for
  // SS-cap and Medicare-surcharge math; preserved for paystub display.
  ytdWages           Decimal           @default(0) @db.Decimal(12, 2)
  ytdMedicareWages   Decimal           @default(0) @db.Decimal(12, 2)
  // Phase 42 — pre-tax benefit deductions taken this period. Reduced
  // from gross before federal/FICA/Medicare/state are computed; also
  // subtracted again from net to land on take-home. Stored as a sum
  // here; per-plan breakdown lives in BenefitsEnrollment + the period.
  preTaxDeductions   Decimal           @default(0) @db.Decimal(12, 2)
  // Wave 4.2 — post-tax deductions taken this period (garnishments,
  // Roth 401k, etc.). Subtracted AFTER taxes to land on take-home; does
  // NOT affect FIT/FICA/Medicare/SIT bases. Per-deduction breakdown for
  // garnishments lives in GarnishmentDeduction rows tied to the run.
  postTaxDeductions  Decimal           @default(0) @db.Decimal(12, 2)
  netPay             Decimal           @db.Decimal(12, 2)
  // The state used for SIT lookup (snapshot of associate.state at compute
  // time). Lets the paystub label the SIT line and the auditor see why a
  // CA-rate was applied to someone who later moved to TX.
  taxState           String?
  status             PayrollItemStatus @default(PENDING)
  // sha256 of the rendered paystub PDF the FIRST time it was downloaded.
  // Subsequent downloads must produce the same hash; verifies immutability.
  paystubHash        String?
  // Stub for now; in production this is the Wise transfer ID or Branch txn ID.
  disbursementRef    String?
  disbursedAt        DateTime?         @db.Timestamptz(6)
  failureReason      String?
  payrollRun         PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  associate          Associate         @relation(fields: [associateId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)

  // Phase 22 — every disbursement call (success or fail) appends a row
  // here, even retries. PayrollItem.disbursementRef stores the latest
  // SUCCESS ref; this table preserves the full attempt history for audit.
  disbursementAttempts PayrollDisbursementAttempt[]

  // Wave 1.2 — per-kind earning breakdown that sums to grossPay. The legacy
  // hoursWorked / hourlyRate / grossPay columns are kept for back-compat
  // with paystub PDFs and aggregate reports — earnings is the canonical
  // breakdown going forward.
  earnings PayrollItemEarning[]

  // One paystub per (run, associate) — re-aggregating updates in place
  // rather than duplicating.
  @@unique([payrollRunId, associateId])
  @@index([associateId])
  @@index([status])
}

// Wave 1.2 — One row per earning line on a paystub. The sum of all
// `amount` rows for a PayrollItem equals its grossPay (re-aggregation
// invariant). Hours/rate are nullable because non-hourly earnings (BONUS,
// REIMBURSEMENT, TIPS) are flat amounts. REIMBURSEMENT is non-taxable —
// we still surface it on the stub but it doesn't roll into taxable wages
// (the run-creation code excludes it from the FIT/FICA/Medicare base).
model PayrollItemEarning {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollItemId String             @db.Uuid
  kind          PayrollEarningKind
  hours         Decimal?           @db.Decimal(8, 2)
  rate          Decimal?           @db.Decimal(8, 2)
  amount        Decimal            @db.Decimal(12, 2)
  // True for REIMBURSEMENT and any future fringe benefits we surface as
  // non-taxable. The run aggregator excludes these from taxable wages.
  isTaxable     Boolean            @default(true)
  notes         String?
  payrollItem   PayrollItem        @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)

  @@index([payrollItemId])
}

// Phase 22 — disbursement attempt log. One row per provider call, regardless
// of outcome. Lets finance reconstruct "who got paid when, by which provider,
// for which run" without trusting that PayrollItem.disbursementRef is
// authoritative (it isn't — retries overwrite it).
model PayrollDisbursementAttempt {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollItemId String      @db.Uuid
  provider      String
  status        String // SUCCESS | PENDING | FAILED (mirrors DisbursementResult.status)
  externalRef   String?
  failureReason String?
  attemptedAt   DateTime    @default(now()) @db.Timestamptz(6)
  attemptedById String?     @db.Uuid
  payrollItem   PayrollItem @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  attemptedBy   User?       @relation("PayrollDisbursementAttemptActor", fields: [attemptedById], references: [id], onDelete: SetNull)

  @@index([payrollItemId, attemptedAt])
  @@index([status])
}

// Wave 1.1 — Pay schedules. A named cadence + anchor date that drives the
// payroll run wizard's "next period to run" computation. Mirrors QuickBooks
// Online Payroll's "Pay schedules" concept: clients have one or more (e.g.
// "Hourly biweekly" + "Salaried monthly") and each Associate is assigned to
// exactly one. clientId is nullable so Alto can define org-wide defaults.
//
// anchorDate is the reference point for cadence math:
//   WEEKLY      → period = Mon..Sun of the week containing anchorDate
//                 (subsequent periods = +7d each)
//   BIWEEKLY    → period = anchorDate..anchorDate+13d (subsequent = +14d)
//   SEMIMONTHLY → periods = 1st..15th and 16th..end-of-month every month
//                 (anchorDate's month determines first period)
//   MONTHLY     → period = 1st..last-day of anchorDate's month, then +1mo
//
// payDateOffsetDays = days after periodEnd that funds disburse (default 5
// = "pay on Friday for a Mon..Sun period"). Used by the wizard to display
// "next pay date" and to schedule QBO journal-entry post date.
model PayrollSchedule {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId          String?          @db.Uuid
  name              String
  frequency         PayrollFrequency
  anchorDate        DateTime         @db.Date
  // Days from periodEnd to actual pay date. Most US employers use 3–7 days
  // (Friday-after-Sun cutoff = 5). Allow 0 if a client cuts cheques same-day.
  payDateOffsetDays Int              @default(5)
  isActive          Boolean          @default(true)
  notes             String?
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?        @db.Timestamptz(6)

  client     Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  associates Associate[]

  @@index([clientId, isActive])
  @@index([deletedAt])
}

model Candidate {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName        String
  lastName         String
  email            String         @unique
  phone            String?
  position         String?
  source           String? // referral, indeed, careers-page, etc.
  stage            CandidateStage @default(APPLIED)
  notes            String?
  // External-careers applicants paste links rather than uploading files
  // (Railway filesystem is ephemeral; direct upload waits for the S3/Volume
  // migration). Both fields are optional and free-form.
  resumeUrl        String?
  linkedinUrl      String?
  // When HIRED, populated with the new Associate's id (and clientId).
  hiredAssociateId String?        @unique @db.Uuid
  hiredClientId    String?        @db.Uuid
  hiredAt          DateTime?      @db.Timestamptz(6)
  rejectedReason   String?
  withdrawnReason  String?
  createdAt        DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?      @db.Timestamptz(6)

  // Phase 90 — recruiting back-relations.
  interviews Interview[]
  offers     Offer[]
  referrals  Referral[]

  @@index([stage])
  @@index([deletedAt])
}

model InviteToken {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // sha256(rawToken) — never store the raw token. The user-facing magic link
  // contains the raw token; the server hashes the lookup key before query.
  tokenHash      String    @unique
  userId         String    @db.Uuid
  expiresAt      DateTime  @db.Timestamptz(6)
  // Single-use: set on accept-invite. Lookups exclude consumedAt != NULL.
  consumedAt     DateTime? @db.Timestamptz(6)
  // Set the first time a reminder email goes out for this token. The 48h
  // sweep skips rows where this is non-null so users get reminded at most
  // once per token. HR-triggered resend always rotates the token (creates
  // a new row), so this never blocks a manual resend.
  reminderSentAt DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
  // Sweep query filters by (consumedAt IS NULL, reminderSentAt IS NULL,
  // expiresAt > now, createdAt < threshold). Composite index covers it.
  @@index([consumedAt, reminderSentAt, createdAt])
}

// Mirror of InviteToken for self-serve password reset. Reset links carry a
// random ~256-bit token; only its sha256 lives in the DB. Tokens are
// single-use (consumedAt) and short-lived (1 hour) to limit the blast
// radius of a leaked email forward. Consuming a token bumps the user's
// tokenVersion, killing every active session — defending against the
// "attacker stole an old reset link before the user reset" case.
model PasswordResetToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash   String    @unique
  userId      String    @db.Uuid
  expiresAt   DateTime  @db.Timestamptz(6)
  consumedAt  DateTime? @db.Timestamptz(6)
  // IP that requested the reset — useful for forensics if a user reports
  // a reset they didn't initiate.
  requestedIp String?   @db.VarChar(64)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

// Per-user opt-out for transactional EMAIL by category bucket. Default
// is "send" — a row exists only when the user has actively muted (or
// re-enabled) something. IN_APP delivery is unaffected; the bell is the
// authoritative record. Mandatory categories (discipline, probation,
// security) cannot be muted — the API rejects the PATCH.
model NotificationPreference {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @db.Uuid
  // Bucket key from NOTIFICATION_CATEGORIES in shared/contracts.
  category     String   @db.VarChar(64)
  emailEnabled Boolean  @default(true)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
}

// Two-step self-serve email change. Issuing a request mints a single-use
// token, hashes it (sha256), and emails the raw token to the NEW address;
// confirming the link swaps User.email and bumps tokenVersion. Older
// outstanding rows for the same user are invalidated when a new one is
// minted — newest request wins.
model EmailChangeRequest {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tokenHash   String    @unique
  userId      String    @db.Uuid
  // The address the user wants to move TO. Already lowercased + validated
  // server-side. Collision against any active User.email is checked at
  // request time AND re-checked at confirm time (race cover).
  newEmail    String    @db.VarChar(254)
  expiresAt   DateTime  @db.Timestamptz(6)
  consumedAt  DateTime? @db.Timestamptz(6)
  requestedIp String?   @db.VarChar(64)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
}

model PerformanceReview {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String                  @db.Uuid
  reviewerUserId String?                 @db.Uuid
  periodStart    DateTime                @db.Date
  periodEnd      DateTime                @db.Date
  overallRating  Int
  summary        String
  strengths      String?
  improvements   String?
  goals          String?
  status         PerformanceReviewStatus @default(DRAFT)
  submittedAt    DateTime?               @db.Timestamptz(6)
  acknowledgedAt DateTime?               @db.Timestamptz(6)
  associate      Associate               @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewer       User?                   @relation("PerformanceReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @db.Timestamptz(6)

  @@index([associateId, periodEnd])
  @@index([status])
}

model Notification {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel         NotificationChannel
  status          NotificationStatus  @default(QUEUED)
  // Recipient: a user (in-app), or by phone/email for SMS/EMAIL when the
  // recipient may not be a User yet.
  recipientUserId String?             @db.Uuid
  recipientPhone  String?
  recipientEmail  String?
  subject         String?
  body            String
  // Optional template/category so HR can filter ("shift_reminder", etc.).
  category        String?
  // Provider's id for the sent message (Twilio SID, FCM message id).
  externalRef     String?
  failureReason   String?
  sentAt          DateTime?           @db.Timestamptz(6)
  readAt          DateTime?           @db.Timestamptz(6)
  // Sender: HR user, or null for system-triggered notifications.
  senderUserId    String?             @db.Uuid
  recipientUser   User?               @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  senderUser      User?               @relation("NotificationSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now()) @db.Timestamptz(6)

  // Sort: Desc — invite-delivery + recent-notification queries always
  // ORDER BY createdAt DESC. Matching index order lets the planner do an
  // in-order index scan instead of reverse-scanning.
  @@index([recipientUserId, createdAt(sort: Desc)])
  @@index([status])
  @@index([category])
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId String?  @db.Uuid
  clientId    String?  @db.Uuid
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  actorUser   User?    @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  // Composite covers (entityType, entityId) prefix queries AND the timeline
  // pattern WHERE entityType=X AND entityId=Y ORDER BY createdAt DESC.
  // Drops the previously-separate (entityType, entityId) index since this
  // composite is a strict superset.
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorUserId])
  @@index([clientId])
  @@index([createdAt])
}

// ===== Phase 42 — Benefits enrollment =====================================
//
// Categories the IRS treats as Section 125 / pre-tax deductions. Every kind
// in this enum is treated as pre-tax in the v1 payroll engine — taxable
// income (federal + FICA + Medicare) drops by the enrolled amount before
// the tax engine runs. Post-tax deductions (e.g. Roth 401k, garnishments)
// will get a separate isPretax flag in a follow-up.
enum BenefitsPlanKind {
  HEALTH_MEDICAL
  DENTAL
  VISION
  HSA
  FSA_HEALTHCARE
  FSA_DEPENDENT_CARE
  RETIREMENT_401K
  RETIREMENT_403B
  LIFE_INSURANCE
  DISABILITY
}

// Per-client benefits offering. The associate-side election picks an amount
// per pay period; the employer side has a flat per-period contribution that
// HR records here for reporting (not currently posted to payroll — only the
// associate election affects taxable income / net pay).
model BenefitsPlan {
  id                                        String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId                                  String           @db.Uuid
  kind                                      BenefitsPlanKind
  name                                      String
  description                               String?
  // Per-pay-period amount the employer contributes. Reporting only for v1.
  employerContributionCentsPerPeriod        Int              @default(0)
  // Default amount shown to the associate when they enroll. They can
  // override; the actual deduction comes from BenefitsEnrollment.
  employeeContributionDefaultCentsPerPeriod Int              @default(0)
  isActive                                  Boolean          @default(true)
  createdAt                                 DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt                                 DateTime         @updatedAt @db.Timestamptz(6)

  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  enrollments BenefitsEnrollment[]

  @@index([clientId, isActive])
  @@index([clientId, kind])
}

// One row per associate × plan. effectiveDate / terminationDate gate whether
// the deduction posts in a given payroll period; null terminationDate means
// "currently enrolled."
model BenefitsEnrollment {
  id                          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId                 String    @db.Uuid
  planId                      String    @db.Uuid
  electedAmountCentsPerPeriod Int
  effectiveDate               DateTime  @db.Date
  terminationDate             DateTime? @db.Date
  createdAt                   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @db.Timestamptz(6)

  associate Associate    @relation(fields: [associateId], references: [id], onDelete: Cascade)
  plan      BenefitsPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  // One active election per (associate, plan) at a time. Re-enrolling after
  // a termination produces a new row (so the history is preserved).
  @@unique([associateId, planId, effectiveDate])
  @@index([associateId, terminationDate])
  @@index([planId])
}

// ===== Phase 44 — QuickBooks Online integration ===========================
//
// Per-client OAuth 2.0 connection to Intuit QuickBooks Online. One row per
// Client (single connection). accessToken / refreshToken are encrypted at
// rest with the same crypto used for SSN / bank accounts (lib/crypto.ts).
// On payroll finalize/disburse, lib/quickbooks.ts builds a JournalEntry
// payload and (when env-configured) posts it via the v3 API; the resulting
// JE id is stamped on PayrollRun.qboJournalEntryId.
// Wave 5.2 — JE granularity. AGGREGATE posts one journal entry per run
// (sum of all paystubs); PER_EMPLOYEE iterates items and posts one JE per
// associate with EmployeeRef set, mirroring how QBO Payroll itself records
// payroll. PER_EMPLOYEE requires that every associate in the run has been
// synced via Wave 3.2 first (qboEmployeeId / qboVendorId set).
enum QboJeMode {
  AGGREGATE
  PER_EMPLOYEE
}

model QuickbooksConnection {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId                 String    @unique @db.Uuid
  realmId                  String // Intuit company / realm identifier
  accessTokenEnc           Bytes
  refreshTokenEnc          Bytes
  expiresAt                DateTime  @db.Timestamptz(6)
  // Intuit may rotate refresh tokens; track the last refresh timestamp
  // so we can warn if it's been > 100 days (their TTL).
  lastRefreshedAt          DateTime  @default(now()) @db.Timestamptz(6)
  // Account ref IDs in QBO that the journal-entry posting needs. HR
  // configures these once per company. NULL = use defaults derived from
  // QBO chart-of-accounts lookup (best-effort, may fail).
  accountSalariesExpense   String?
  accountFederalTaxPayable String?
  accountStateTaxPayable   String?
  accountFicaPayable       String?
  accountMedicarePayable   String?
  accountBenefitsPayable   String?
  accountNetPayPayable     String?
  // Wave 5.2 — per-run vs per-employee JE granularity.
  jeMode                   QboJeMode @default(AGGREGATE)
  createdAt                DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime  @updatedAt @db.Timestamptz(6)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ===== Phase 76 — Org hierarchy ===========================================
//
// Three sibling lookup entities that hang off Client. Department supports
// nested hierarchy via a self-FK; CostCenter is flat; JobProfile is a
// title taxonomy with FLSA exemption flag. Associate carries nullable FKs
// to all three plus a self-FK manager relationship.

model Department {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String    @db.Uuid
  parentId    String?   @db.Uuid
  name        String
  code        String?
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent       Department?   @relation("DepartmentParent", fields: [parentId], references: [id], onDelete: SetNull)
  children     Department[]  @relation("DepartmentParent")
  associates   Associate[]
  positions    Position[]
  // Phase 87 — broadcast targeting.
  broadcasts   Broadcast[]
  // Phase 109 — pulse surveys scoped to this department.
  pulseSurveys PulseSurvey[]

  @@index([clientId, deletedAt])
  @@index([parentId])
}

model CostCenter {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String    @db.Uuid
  code        String
  name        String
  description String?
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  associates Associate[]
  positions  Position[]
  // Phase 87 — broadcast targeting.
  broadcasts Broadcast[]

  @@index([clientId, deletedAt])
}

model JobProfile {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String    @db.Uuid
  code        String
  title       String
  family      String?
  level       String?
  // FLSA exemption flag — exempt salaried employees aren't entitled to
  // overtime under federal rules; surfaced in payroll OT calc later.
  isExempt    Boolean   @default(false)
  description String?
  // Phase 88 — Workers' Comp NCCI / state-specific class code lookup.
  wcClassCode String?   @db.VarChar(10)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  associates   Associate[]
  positions    Position[]
  compBands    CompBand[]
  // Phase 126 — career-ladder rungs that point at this profile.
  careerLevels CareerLevel[]

  @@index([clientId, family])
  @@index([clientId, deletedAt])
}

// ===== Phase 78 — Position ================================================
//
// A seat in the org. May be vacant or filled. Headcount budgeting,
// requisition-driven hiring, and attrition reporting all operate on
// Position, not Associate.
model Position {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId            String         @db.Uuid
  code                String
  title               String
  jobProfileId        String?        @db.Uuid
  departmentId        String?        @db.Uuid
  costCenterId        String?        @db.Uuid
  managerAssociateId  String?        @db.Uuid
  fteAuthorized       Decimal        @default(1.00) @db.Decimal(4, 2)
  status              PositionStatus @default(PLANNED)
  filledByAssociateId String?        @db.Uuid
  filledAt            DateTime?      @db.Timestamptz(6)
  targetStartDate     DateTime?      @db.Date
  minHourlyRate       Decimal?       @db.Decimal(8, 2)
  maxHourlyRate       Decimal?       @db.Decimal(8, 2)
  notes               String?
  createdAt           DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt           DateTime?      @db.Timestamptz(6)

  client         Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  jobProfile     JobProfile?           @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  department     Department?           @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter     CostCenter?           @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  manager        Associate?            @relation("PositionManager", fields: [managerAssociateId], references: [id], onDelete: SetNull)
  filledBy       Associate?            @relation("PositionFilledBy", fields: [filledByAssociateId], references: [id], onDelete: SetNull)
  // Phase 115 — designated successors.
  successionPlan SuccessionCandidate[]

  @@index([clientId, status])
  @@index([filledByAssociateId])
  @@index([departmentId])
  @@index([costCenterId])
  @@index([managerAssociateId])
  @@index([deletedAt])
}

// ===== Phase 77 — Effective-dated AssociateHistory ========================
//
// One row per change to any tracked field. Each row is the snapshot
// from effectiveFrom until effectiveTo (NULL = current). The current row
// mirrors Associate's denormalized current values; this table is the
// audit + as-of source of truth.
model AssociateHistory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId   String    @db.Uuid
  effectiveFrom DateTime  @db.Timestamptz(6)
  effectiveTo   DateTime? @db.Timestamptz(6)
  managerId     String?   @db.Uuid
  departmentId  String?   @db.Uuid
  costCenterId  String?   @db.Uuid
  jobProfileId  String?   @db.Uuid
  state         String?   @db.VarChar(2)
  hourlyRate    Decimal?  @db.Decimal(8, 2)
  reason        String?
  actorUserId   String?   @db.Uuid
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  actor     User?     @relation("AssociateHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([associateId, effectiveFrom(sort: Desc)])
}

// ===== Phase 80 — Workflow engine =========================================

enum WorkflowTrigger {
  ASSOCIATE_HIRED
  ASSOCIATE_TERMINATED
  TIME_OFF_REQUESTED
  TIME_OFF_APPROVED
  TIME_OFF_DENIED
  POSITION_OPENED
  POSITION_FILLED
  PAYROLL_FINALIZED
  ONBOARDING_COMPLETED
  COMPLIANCE_EXPIRING
}

enum WorkflowActionKind {
  SEND_NOTIFICATION
  SET_FIELD
  ASSIGN_TASK
  CREATE_AUDIT_LOG
  WEBHOOK
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum WorkflowStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model WorkflowDefinition {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?         @db.Uuid
  name        String
  description String?
  trigger     WorkflowTrigger
  // {} = always run; supports { and: [{ field, op, value }] }
  conditions  Json            @default("{}")
  // [{ kind, params }, ...]
  actions     Json            @default("[]")
  isActive    Boolean         @default(true)
  createdById String?         @db.Uuid
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?       @db.Timestamptz(6)

  client    Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?         @relation("WorkflowDefinitionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  runs      WorkflowRun[]

  @@index([trigger, isActive])
  @@index([clientId])
}

model WorkflowRun {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  definitionId  String            @db.Uuid
  trigger       WorkflowTrigger
  entityType    String
  entityId      String
  context       Json              @default("{}")
  status        WorkflowRunStatus @default(PENDING)
  startedAt     DateTime?         @db.Timestamptz(6)
  completedAt   DateTime?         @db.Timestamptz(6)
  failureReason String?
  createdAt     DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime          @updatedAt @db.Timestamptz(6)

  definition WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  steps      WorkflowStep[]

  @@index([definitionId, status])
  @@index([entityType, entityId])
  @@index([status, createdAt(sort: Desc)])
}

model WorkflowStep {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  runId         String             @db.Uuid
  ordinal       Int
  kind          WorkflowActionKind
  params        Json               @default("{}")
  status        WorkflowStepStatus @default(PENDING)
  result        Json?
  failureReason String?
  startedAt     DateTime?          @db.Timestamptz(6)
  completedAt   DateTime?          @db.Timestamptz(6)
  createdAt     DateTime           @default(now()) @db.Timestamptz(6)

  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, ordinal])
  @@index([runId])
  @@index([status])
}

