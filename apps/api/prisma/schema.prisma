// Alto People — Prisma schema (Phase 2)
// Conventions:
// - UUID primary keys (gen_random_uuid)
// - Timestamptz timestamps everywhere
// - deletedAt on PII / compliance-relevant tables (retention then delete)
// - Explicit onDelete on every relation
// - Denormalized clientId on documents/bg-checks/audit-log for future RLS
// - Money: Decimal(12,2). Encrypted PII: Bytes. Files: S3 keys, never blobs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  EXECUTIVE_CHAIRMAN
  HR_ADMINISTRATOR
  OPERATIONS_MANAGER
  LIVE_ASN
  ASSOCIATE
  CLIENT_PORTAL
  FINANCE_ACCOUNTANT
  INTERNAL_RECRUITER
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum OnboardingTrack {
  STANDARD
  J1
  CLIENT_SPECIFIC
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum TaskKind {
  PROFILE_INFO
  DOCUMENT_UPLOAD
  E_SIGN
  BACKGROUND_CHECK
  W4
  DIRECT_DEPOSIT
  POLICY_ACK
  J1_DOCS
  I9_VERIFICATION
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum DocumentKind {
  ID
  SSN_CARD
  I9_SUPPORTING
  W4_PDF
  OFFER_LETTER
  POLICY
  HOUSING_AGREEMENT
  TRANSPORT_AGREEMENT
  J1_DS2019
  J1_VISA
  // Phase 19 — server-rendered signed agreement PDF (typed-name e-sign).
  SIGNED_AGREEMENT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  VERIFIED
  REJECTED
  EXPIRED
}

enum BgCheckStatus {
  INITIATED
  IN_PROGRESS
  PASSED
  FAILED
  NEEDS_REVIEW
}

enum PayoutType {
  BANK_ACCOUNT
  BRANCH_CARD
}

enum W4FilingStatus {
  SINGLE
  MARRIED_FILING_JOINTLY
  HEAD_OF_HOUSEHOLD
}

// Phase 41 — distinguishes W-2 employees (subject to W-4, FICA, Medicare,
// FUTA/SUTA, federal/state withholding) from 1099 contractors (paid gross,
// no withholding, no employer-side payroll tax). Drives onboarding
// checklist (1099s skip W-4) and payroll computation (1099 line items
// have all tax fields zeroed; gross == net).
enum EmploymentType {
  W2_EMPLOYEE
  CONTRACTOR_1099_INDIVIDUAL
  CONTRACTOR_1099_BUSINESS
}

enum I9DocumentList {
  LIST_A
  LIST_B_AND_C
}

// USCIS Form I-9 Section 1 citizenship attestation. The employee picks
// exactly one — Phase 20 self-attest endpoint enforces that.
enum I9CitizenshipStatus {
  US_CITIZEN
  NON_CITIZEN_NATIONAL
  LAWFUL_PERMANENT_RESIDENT
  ALIEN_AUTHORIZED_TO_WORK
}

enum TimeEntryStatus {
  ACTIVE      // clocked in, not yet out
  COMPLETED   // clocked out, awaiting review
  APPROVED    // HR/Ops approved for payroll
  REJECTED    // HR/Ops rejected (associate must edit + resubmit)
}

enum ShiftStatus {
  DRAFT       // HR scratch pad, not yet open for assignment
  OPEN        // published, no one assigned
  ASSIGNED    // associate accepted (or HR assigned)
  COMPLETED   // worked
  CANCELLED   // pulled
}

enum PayrollRunStatus {
  DRAFT       // newly created, items aggregated, can be edited
  FINALIZED   // locked for review, ready to disburse
  DISBURSED   // funds sent (real or stubbed)
  CANCELLED
}

enum PayrollItemStatus {
  PENDING     // computed, not yet sent
  DISBURSED   // sent (with disbursementRef)
  FAILED      // disbursement attempt failed
  HELD        // HR put a hold on this single item
}

enum NotificationChannel {
  SMS         // Twilio (Phase 12 stubbed)
  PUSH        // FCM (Phase 12 stubbed)
  EMAIL       // SES / Resend (Phase 12 stubbed)
  IN_APP      // delivered via the web inbox; no external service
}

enum NotificationStatus {
  QUEUED      // accepted, not yet sent
  SENT        // delivered to provider (or in-app written)
  FAILED      // provider returned an error
  READ        // IN_APP only — recipient opened it
}

enum PerformanceReviewStatus {
  DRAFT          // HR is still composing — not visible to associate
  SUBMITTED      // visible to associate, awaiting acknowledgement
  ACKNOWLEDGED   // associate has read + signed off
}

enum CandidateStage {
  APPLIED        // record exists, hasn't been screened yet
  SCREENING      // recruiter is reviewing
  INTERVIEW      // interview scheduled / in progress
  OFFER          // offer extended, awaiting response
  HIRED          // accepted; converted to Associate
  WITHDRAWN      // candidate pulled out
  REJECTED       // we passed
}

enum BreakType {
  MEAL           // 30+ min unpaid (state-dependent)
  REST           // 10-15 min paid
}

enum ShiftSwapStatus {
  PENDING_PEER       // sent to counterparty associate
  PEER_ACCEPTED      // counterparty agreed; awaiting manager approval
  PEER_DECLINED      // counterparty refused
  MANAGER_APPROVED   // executed — shift assignment swapped
  MANAGER_REJECTED   // manager refused after peer accepted
  CANCELLED          // requester pulled it
}

// =============================================================================
// Models
// =============================================================================

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String     @unique
  passwordHash  String?    @db.VarChar(255)
  role          Role
  status        UserStatus @default(INVITED)
  tokenVersion  Int        @default(0)
  associateId   String?    @unique @db.Uuid
  clientId      String?    @db.Uuid
  associate     Associate? @relation(fields: [associateId], references: [id], onDelete: SetNull)
  client        Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt     DateTime?  @db.Timestamptz(6)

  signaturesGiven       Signature[]            @relation("UserSignatures")
  i9VerificationsAsRep  I9Verification[]       @relation("I9Verifier")
  auditLogActions       AuditLog[]             @relation("AuditActor")
  timeApprovals         TimeEntry[]            @relation("TimeApprover")
  createdShifts         Shift[]                @relation("ShiftCreator")
  createdPayrollRuns    PayrollRun[]           @relation("PayrollRunCreator")
  verifiedDocuments     DocumentRecord[]       @relation("DocumentVerifier")
  sentNotifications     Notification[]         @relation("NotificationSender")
  receivedNotifications Notification[]         @relation("NotificationRecipient")
  authoredReviews       PerformanceReview[]    @relation("PerformanceReviewer")
  inviteTokens          InviteToken[]
  createdEsignAgreements EsignAgreement[]      @relation("EsignAgreementCreator")
  payrollDisbursementAttempts PayrollDisbursementAttempt[] @relation("PayrollDisbursementAttemptActor")
  timeOffLedgerEntriesAuthored TimeOffLedgerEntry[]
  timeOffReviews               TimeOffRequest[]               @relation("TimeOffReviewer")

  @@index([role])
  @@index([clientId])
  @@index([deletedAt])
}

model Client {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  industry             String?
  status               ClientStatus @default(ACTIVE)
  contactEmail         String?
  // Two-letter USPS code of the work site. Drives Phase 23 OT/meal-break
  // policy AND Phase 25 predictive-scheduling enforcement (NY, IL, WA, PA,
  // OR demand 14-day notice). Null = federal default = no state-specific
  // rules enforced.
  state                String?      @db.VarChar(2)
  // Geofence anchor for clock-in validation. NULL latitude/longitude means
  // no geofence enforced (associates can clock in from anywhere).
  // Stored as Decimal for precision; ~5cm at 7 decimals.
  latitude             Decimal?     @db.Decimal(10, 7)
  longitude            Decimal?     @db.Decimal(10, 7)
  geofenceRadiusMeters Int?
  createdAt            DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?    @db.Timestamptz(6)

  applications Application[]
  users        User[]
  policies     Policy[]
  templates    OnboardingTemplate[]
  shifts       Shift[]
  payrollRuns  PayrollRun[]
  jobs         Job[]

  @@index([status])
  @@index([deletedAt])
}

model Associate {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String
  lastName     String
  dob          DateTime? @db.Date
  email        String    @unique
  phone        String?
  ssnLast4     String?   @db.VarChar(4)
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?   @db.VarChar(2)
  zip          String?   @db.VarChar(10)
  j1Status     Boolean   @default(false)
  // Phase 41 — W-2 vs 1099. Default W2 keeps every existing record's
  // payroll math identical; 1099 records skip W-4 / FICA / Medicare.
  employmentType EmploymentType @default(W2_EMPLOYEE)
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime? @db.Timestamptz(6)

  user             User?
  j1Profile        J1Profile?
  applications     Application[]
  documents        DocumentRecord[]
  signatures       Signature[]            @relation("AssociateSignatures")
  backgroundChecks BackgroundCheck[]
  policyAcks       PolicyAcknowledgment[]
  i9Verification   I9Verification?
  w4Submission     W4Submission?
  payoutMethods    PayoutMethod[]
  timeEntries      TimeEntry[]
  assignedShifts   Shift[]
  payrollItems     PayrollItem[]
  performanceReviews PerformanceReview[]
  availability       AssociateAvailability[]
  swapsRequested     ShiftSwapRequest[] @relation("SwapRequester")
  swapsReceived      ShiftSwapRequest[] @relation("SwapCounterparty")
  timeOffBalances    TimeOffBalance[]
  timeOffLedger      TimeOffLedgerEntry[]
  timeOffRequests    TimeOffRequest[]

  @@index([deletedAt])
}

model J1Profile {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId       String    @unique @db.Uuid
  programStartDate  DateTime  @db.Date
  programEndDate    DateTime  @db.Date
  ds2019Number      String
  sponsorAgency     String
  visaNumber        String?
  sevisId           String?
  country           String
  associate         Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
}

model Application {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId     String              @db.Uuid
  clientId        String              @db.Uuid
  onboardingTrack OnboardingTrack
  status          ApplicationStatus   @default(DRAFT)
  position        String?
  startDate       DateTime?           @db.Date
  invitedAt       DateTime            @default(now()) @db.Timestamptz(6)
  submittedAt     DateTime?           @db.Timestamptz(6)
  associate       Associate           @relation(fields: [associateId], references: [id], onDelete: Restrict)
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  checklist       OnboardingChecklist?
  esignAgreements EsignAgreement[]
  createdAt       DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime            @updatedAt @db.Timestamptz(6)
  deletedAt       DateTime?           @db.Timestamptz(6)

  @@index([associateId])
  @@index([clientId, status])
  @@index([status])
  @@index([invitedAt])
  @@index([deletedAt])
}

model OnboardingChecklist {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String           @unique @db.Uuid
  application   Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tasks         OnboardingTask[]
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)
}

model OnboardingTask {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  checklistId String              @db.Uuid
  kind        TaskKind
  status      TaskStatus          @default(PENDING)
  title       String
  description String?
  order       Int
  documentId  String?             @db.Uuid
  completedAt DateTime?           @db.Timestamptz(6)
  checklist   OnboardingChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  document    DocumentRecord?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  esignAgreements EsignAgreement[]
  createdAt   DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @db.Timestamptz(6)

  @@index([checklistId])
  @@index([status])
}

model OnboardingTemplate {
  id        String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId  String?                  @db.Uuid
  track     OnboardingTrack
  name      String
  client    Client?                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks     OnboardingTemplateTask[]
  createdAt DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt DateTime                 @updatedAt @db.Timestamptz(6)

  @@unique([clientId, track])
  @@index([track])
}

model OnboardingTemplateTask {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId  String             @db.Uuid
  kind        TaskKind
  title       String
  description String?
  order       Int
  template    OnboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Policy {
  id                    String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId              String?                @db.Uuid
  industry              String?
  title                 String
  version               String
  bodyUrl               String?
  requiredForOnboarding Boolean                @default(true)
  supersedesId          String?                @db.Uuid
  client                Client?                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supersedes            Policy?                @relation("PolicyVersions", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy          Policy[]               @relation("PolicyVersions")
  acknowledgments       PolicyAcknowledgment[]
  createdAt             DateTime               @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime               @updatedAt @db.Timestamptz(6)
  deletedAt             DateTime?              @db.Timestamptz(6)

  @@index([clientId])
  @@index([industry])
}

model PolicyAcknowledgment {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId       String     @db.Uuid
  associateId    String     @db.Uuid
  clientId       String?    @db.Uuid
  signatureId    String?    @db.Uuid
  acknowledgedAt DateTime   @default(now()) @db.Timestamptz(6)
  policy         Policy     @relation(fields: [policyId], references: [id], onDelete: Restrict)
  associate      Associate  @relation(fields: [associateId], references: [id], onDelete: Cascade)
  signature      Signature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)

  @@unique([policyId, associateId])
  @@index([associateId])
  @@index([policyId])
  @@index([clientId])
}

model DocumentRecord {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId      String            @db.Uuid
  clientId         String?           @db.Uuid
  kind             DocumentKind
  s3Key            String?
  filename         String
  mimeType         String
  size             Int
  status           DocumentStatus    @default(UPLOADED)
  expiresAt        DateTime?         @db.Timestamptz(6)
  rejectionReason  String?
  verifiedById     String?           @db.Uuid
  verifiedAt       DateTime?         @db.Timestamptz(6)
  associate        Associate         @relation(fields: [associateId], references: [id], onDelete: Restrict)
  verifiedBy       User?             @relation("DocumentVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)
  signatures       Signature[]
  tasks            OnboardingTask[]
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?         @db.Timestamptz(6)

  @@index([associateId, kind])
  @@index([status])
  @@index([expiresAt])
  @@index([clientId])
  @@index([deletedAt])
}

model Signature {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId      String                 @db.Uuid
  signerUserId    String?                @db.Uuid
  associateId     String?                @db.Uuid
  signedAt        DateTime               @default(now()) @db.Timestamptz(6)
  ipAddress       String?
  userAgent       String?
  signatureS3Key  String
  // Phase 19 — when this Signature row was produced by the typed-name
  // e-sign flow (rather than uploaded out-of-band), agreementId points at
  // the EsignAgreement that was signed. typedName is exactly what the
  // signer typed (immutable proof). pdfHash is sha256 of the rendered
  // signed PDF — a future re-render must hash to the same value.
  agreementId     String?                @db.Uuid
  typedName       String?
  pdfHash         String?
  agreement       EsignAgreement?        @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  document        DocumentRecord         @relation(fields: [documentId], references: [id], onDelete: Restrict)
  signerUser      User?                  @relation("UserSignatures", fields: [signerUserId], references: [id], onDelete: SetNull)
  associate       Associate?             @relation("AssociateSignatures", fields: [associateId], references: [id], onDelete: SetNull)
  policyAcks      PolicyAcknowledgment[]

  @@index([documentId])
  @@index([signerUserId])
  @@index([associateId])
  @@index([agreementId])
}

// Phase 19 — server-side typed-name e-signature.
//
// HR creates an EsignAgreement attached to an Application (and optionally
// the OnboardingTask of kind E_SIGN that triggers it). The body is plain
// text that gets rendered into a PDF at sign time, with a signature block
// (typed name + IP + UA + signedAt + sha256 of the rendered bytes) so the
// signed PDF carries its own audit trail. Each successful signing creates
// exactly one Signature row; duplicate sign attempts return 409. The
// agreement itself is immutable once signed.
model EsignAgreement {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  applicationId String       @db.Uuid
  // Optional link to the onboarding checklist task — when set, signing
  // this agreement marks that task DONE.
  taskId        String?      @db.Uuid
  title         String
  // Plain-text agreement body (markdown-light: \n linebreaks). Renderer
  // wraps it into the PDF as paragraphs; no HTML/script execution.
  body          String
  createdById   String       @db.Uuid
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  // Once signed, signedAt mirrors the Signature row for fast dashboard
  // queries. Null = unsigned.
  signedAt      DateTime?    @db.Timestamptz(6)
  signatureId   String?      @db.Uuid
  application   Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  task          OnboardingTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)
  createdBy     User         @relation("EsignAgreementCreator", fields: [createdById], references: [id], onDelete: Restrict)
  signatures    Signature[]

  @@index([applicationId])
  @@index([taskId])
  @@index([signedAt])
}

model BackgroundCheck {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId String        @db.Uuid
  clientId    String?       @db.Uuid
  provider    String
  externalId  String?
  status      BgCheckStatus @default(INITIATED)
  initiatedAt DateTime      @default(now()) @db.Timestamptz(6)
  completedAt DateTime?     @db.Timestamptz(6)
  associate   Associate     @relation(fields: [associateId], references: [id], onDelete: Restrict)

  @@index([associateId])
  @@index([status])
  @@index([clientId])
}

model I9Verification {
  id                       String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId              String              @unique @db.Uuid
  section1CompletedAt      DateTime?           @db.Timestamptz(6)
  // Phase 20 — Section 1 employee self-attestation fields. citizenshipStatus
  // is the exclusive choice the employee picks. alienRegistrationNumberEnc
  // is encrypted at rest (same key as W-4 SSN); workAuthExpiresAt applies
  // only to ALIEN_AUTHORIZED_TO_WORK (or LAWFUL_PERMANENT_RESIDENT with an
  // expiring USCIS number). section1TypedName + IP + userAgent capture the
  // typed-name e-signature exactly per Phase 19's pattern.
  citizenshipStatus        I9CitizenshipStatus?
  alienRegistrationNumberEnc Bytes?
  workAuthExpiresAt        DateTime?           @db.Date
  section1TypedName        String?
  section1Ip               String?
  section1UserAgent        String?
  section2VerifierUserId   String?             @db.Uuid
  section2CompletedAt      DateTime?           @db.Timestamptz(6)
  documentList             I9DocumentList?
  supportingDocIds         Json?
  associate                Associate           @relation(fields: [associateId], references: [id], onDelete: Cascade)
  section2Verifier         User?               @relation("I9Verifier", fields: [section2VerifierUserId], references: [id], onDelete: SetNull)
  createdAt                DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime            @updatedAt @db.Timestamptz(6)
}

model W4Submission {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId       String          @unique @db.Uuid
  filingStatus      W4FilingStatus
  multipleJobs      Boolean         @default(false)
  dependentsAmount  Decimal         @default(0) @db.Decimal(12, 2)
  otherIncome       Decimal         @default(0) @db.Decimal(12, 2)
  deductions        Decimal         @default(0) @db.Decimal(12, 2)
  extraWithholding  Decimal         @default(0) @db.Decimal(12, 2)
  ssnEncrypted      Bytes?
  signedDocumentId  String?         @db.Uuid
  signedAt          DateTime?       @db.Timestamptz(6)
  associate         Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime        @updatedAt @db.Timestamptz(6)
}

model PayoutMethod {
  id               String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId      String     @db.Uuid
  type             PayoutType
  routingNumberEnc Bytes?
  accountNumberEnc Bytes?
  accountType      String?
  branchCardId     String?
  isPrimary        Boolean    @default(false)
  verifiedAt       DateTime?  @db.Timestamptz(6)
  associate        Associate  @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdAt        DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime   @updatedAt @db.Timestamptz(6)

  @@index([associateId])
}

model TimeEntry {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId   String          @db.Uuid
  // Denormalized clientId so HR can scope/filter by client without joining.
  // Captured from the Associate's currently-assigned client at clock-in.
  clientId      String?         @db.Uuid
  // Optional Job for cost-coding. Null means generic / undifferentiated time.
  jobId         String?         @db.Uuid
  clockInAt     DateTime        @db.Timestamptz(6)
  clockOutAt    DateTime?       @db.Timestamptz(6)
  // GPS coords captured from the associate's device at each transition.
  // Used for geofence audit; nullable so the partial-unique still works
  // and so older entries (pre-geofence) aren't broken.
  clockInLat    Decimal?        @db.Decimal(10, 7)
  clockInLng    Decimal?        @db.Decimal(10, 7)
  clockOutLat   Decimal?        @db.Decimal(10, 7)
  clockOutLng   Decimal?        @db.Decimal(10, 7)
  // Snapshotted pay rate at clock-in time for payroll repeatability.
  payRate       Decimal?        @db.Decimal(8, 2)
  status        TimeEntryStatus @default(ACTIVE)
  notes         String?
  // Tags surfaced in the HR queue: NO_BREAK, OVERTIME_UNAPPROVED,
  // GEOFENCE_VIOLATION, FORGOT_CLOCKOUT, MEAL_BREAK_TOO_SHORT, etc.
  // Computed at clock-out and re-computed on edit.
  anomalies     Json?
  rejectionReason String?
  approvedById  String?         @db.Uuid
  approvedAt    DateTime?       @db.Timestamptz(6)
  associate     Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)
  approvedBy    User?           @relation("TimeApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  job           Job?            @relation(fields: [jobId], references: [id], onDelete: SetNull)
  breaks        BreakEntry[]
  timeOffLedgerEntries TimeOffLedgerEntry[]
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(6)

  // At most one ACTIVE row per associate at any time. Postgres treats this
  // as a partial unique via the where clause below.
  @@index([associateId, clockInAt])
  @@index([clientId, status])
  @@index([status])
  @@index([jobId])
}

model Shift {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId             String      @db.Uuid
  position             String
  startsAt             DateTime    @db.Timestamptz(6)
  endsAt               DateTime    @db.Timestamptz(6)
  location             String?
  // What the client is billed (revenue side).
  hourlyRate           Decimal?    @db.Decimal(8, 2)
  // What the associate is paid (cost side). null = use Job.payRate or default.
  payRate              Decimal?    @db.Decimal(8, 2)
  status               ShiftStatus @default(DRAFT)
  notes                String?
  assignedAssociateId  String?     @db.Uuid
  assignedAt           DateTime?   @db.Timestamptz(6)
  createdById          String?     @db.Uuid
  cancelledAt          DateTime?   @db.Timestamptz(6)
  cancellationReason   String?
  // Phase 25 — stamped the first time the shift transitions out of DRAFT
  // (= "schedule was published"). Combined with startsAt, this is the
  // notice window every fair-workweek law audits against.
  publishedAt          DateTime?   @db.Timestamptz(6)
  // Documented justification when a shift in a fair-workweek state was
  // published inside the 14-day notice window (mutual agreement,
  // emergency call-out cover, etc.). Required by the API for those cases.
  lateNoticeReason     String?
  client               Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  assignedAssociate    Associate?  @relation(fields: [assignedAssociateId], references: [id], onDelete: SetNull)
  createdBy            User?       @relation("ShiftCreator", fields: [createdById], references: [id], onDelete: SetNull)
  swapRequests         ShiftSwapRequest[]
  createdAt            DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime    @updatedAt @db.Timestamptz(6)

  @@index([clientId, startsAt])
  @@index([assignedAssociateId, startsAt])
  @@index([status, startsAt])
}

model Job {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String      @db.Uuid
  name         String
  // Default rates if a Shift doesn't override. Bill = revenue, pay = cost.
  billRate     Decimal?    @db.Decimal(8, 2)
  payRate      Decimal?    @db.Decimal(8, 2)
  isActive     Boolean     @default(true)
  client       Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  timeEntries  TimeEntry[]
  createdAt    DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?   @db.Timestamptz(6)

  @@unique([clientId, name])
  @@index([clientId, isActive])
}

model BreakEntry {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timeEntryId   String     @db.Uuid
  type          BreakType
  startedAt     DateTime   @db.Timestamptz(6)
  endedAt       DateTime?  @db.Timestamptz(6)
  timeEntry     TimeEntry  @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  @@index([timeEntryId])
}

// Phase 26 — time-off categories. Sick is the only one accruing
// automatically today (driven by StateLaborPolicy.paidSickLeaveAccrualPerHour
// when a TimeEntry is approved). VACATION/PTO/etc. exist in the enum so the
// later request-flow phase doesn't need a schema migration.
enum TimeOffCategory {
  SICK
  VACATION
  PTO
  BEREAVEMENT
  JURY_DUTY
  OTHER
}

// Source of a ledger entry. ACCRUAL = automatic from worked time.
// USE = consumed by an approved time-off request. ADJUSTMENT = HR
// manually credited or debited (carryover at year boundary, dispute fix,
// etc.). PAYOUT = associate cashed out at termination.
enum TimeOffLedgerReason {
  ACCRUAL
  USE
  ADJUSTMENT
  PAYOUT
}

model TimeOffBalance {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String          @db.Uuid
  category       TimeOffCategory
  // Stored in MINUTES so we don't lose precision on fractional accrual
  // (CA: 1hr per 30hrs = 2 min per worked hour). Convert to hours at the
  // edge for display.
  balanceMinutes Int             @default(0)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  associate      Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([associateId, category])
  @@index([associateId])
}

model TimeOffLedgerEntry {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId        String              @db.Uuid
  category           TimeOffCategory
  reason             TimeOffLedgerReason
  // Signed: +N for accrual/credit, -N for use/payout.
  deltaMinutes       Int
  // Optional foreign keys so we can audit-trail back to the source.
  // sourceTimeEntryId is the worked entry that drove an ACCRUAL row.
  sourceTimeEntryId  String?             @db.Uuid
  // Phase 30 — the request that drove a USE row. One USE entry per request.
  sourceRequestId    String?             @unique @db.Uuid
  sourceUserId       String?             @db.Uuid
  notes              String?
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  associate          Associate           @relation(fields: [associateId], references: [id], onDelete: Cascade)
  sourceTimeEntry    TimeEntry?          @relation(fields: [sourceTimeEntryId], references: [id], onDelete: SetNull)
  sourceRequest      TimeOffRequest?     @relation(fields: [sourceRequestId], references: [id], onDelete: SetNull)
  sourceUser         User?               @relation(fields: [sourceUserId], references: [id], onDelete: SetNull)

  // Idempotency guard for the accrual hook: one accrual row per (entry,
  // category). If the approve handler runs twice we no-op.
  @@unique([sourceTimeEntryId, category, reason], name: "uniq_accrual_per_entry")
  @@index([associateId, createdAt])
}

// Phase 30 — associate-submitted time-off request and its approval state.
// Approval is the single point that debits the balance ledger; denial /
// cancellation never touches the ledger. The unique sourceRequestId on
// TimeOffLedgerEntry guarantees at-most-one USE entry per request even if
// the approve handler is retried.
enum TimeOffRequestStatus {
  PENDING
  APPROVED
  DENIED
  CANCELLED
}

model TimeOffRequest {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId     String               @db.Uuid
  category        TimeOffCategory
  // Inclusive day range. We store dates (not timestamps) because requests
  // are scheduled at day granularity; the UI picks days, not minutes.
  startDate       DateTime             @db.Date
  endDate         DateTime             @db.Date
  // Hours requested in MINUTES so the unit matches the ledger and balance.
  // We store minutes (not days) because part-days are valid (a half-day off
  // = 240 min for an 8h schedule) and we'd lose precision converting twice.
  requestedMinutes Int
  reason          String?
  status          TimeOffRequestStatus  @default(PENDING)
  reviewerUserId  String?              @db.Uuid
  reviewerNote    String?
  decidedAt       DateTime?            @db.Timestamptz(6)
  cancelledAt     DateTime?            @db.Timestamptz(6)
  createdAt       DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @db.Timestamptz(6)

  associate       Associate            @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewer        User?                @relation("TimeOffReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  ledgerEntry     TimeOffLedgerEntry?

  @@index([associateId, status])
  @@index([status, createdAt])
}

model AssociateAvailability {
  id                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId          String     @db.Uuid
  // 0 = Sunday … 6 = Saturday
  dayOfWeek            Int
  // Minutes since midnight: 480 = 08:00, 1080 = 18:00.
  startMinute          Int
  endMinute            Int
  associate            Associate  @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdAt            DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @db.Timestamptz(6)

  @@index([associateId, dayOfWeek])
}

model ShiftSwapRequest {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId             String          @db.Uuid
  requesterAssociateId String         @db.Uuid
  // Counterparty associate the requester proposes the swap to. They must
  // accept before HR/Ops sees it for final approval.
  counterpartyAssociateId String      @db.Uuid
  status              ShiftSwapStatus @default(PENDING_PEER)
  note                String?
  decidedById         String?         @db.Uuid
  decidedAt           DateTime?       @db.Timestamptz(6)
  shift               Shift           @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  requester           Associate       @relation("SwapRequester", fields: [requesterAssociateId], references: [id], onDelete: Cascade)
  counterparty        Associate       @relation("SwapCounterparty", fields: [counterpartyAssociateId], references: [id], onDelete: Cascade)
  createdAt           DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime        @updatedAt @db.Timestamptz(6)

  @@index([shiftId])
  @@index([counterpartyAssociateId, status])
  @@index([requesterAssociateId, status])
}

model PayrollRun {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // clientId is nullable so a run can span all clients (Alto-internal payroll).
  clientId      String?          @db.Uuid
  periodStart   DateTime         @db.Date
  periodEnd     DateTime         @db.Date
  status        PayrollRunStatus @default(DRAFT)
  totalGross    Decimal          @default(0) @db.Decimal(12, 2)
  totalTax      Decimal          @default(0) @db.Decimal(12, 2)
  totalNet      Decimal          @default(0) @db.Decimal(12, 2)
  // Phase 18 — employer-side total (FICA match + Medicare match + FUTA + SUTA)
  // is the company's true cost on top of totalGross. Used in finance reports.
  totalEmployerTax Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  createdById   String?          @db.Uuid
  finalizedAt   DateTime?        @db.Timestamptz(6)
  disbursedAt   DateTime?        @db.Timestamptz(6)
  cancelledAt   DateTime?        @db.Timestamptz(6)
  client        Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy     User?            @relation("PayrollRunCreator", fields: [createdById], references: [id], onDelete: SetNull)
  items         PayrollItem[]
  createdAt     DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @db.Timestamptz(6)

  @@index([clientId, periodStart])
  @@index([status])
}

model PayrollItem {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollRunId       String            @db.Uuid
  associateId        String            @db.Uuid
  // Snapshot of inputs at the time of aggregation. Source TimeEntries /
  // Shifts can change later (e.g. a bug-fix amendment), but the paystub
  // record is immutable.
  hoursWorked        Decimal           @db.Decimal(8, 2)
  hourlyRate         Decimal           @db.Decimal(8, 2)
  grossPay           Decimal           @db.Decimal(12, 2)
  // Phase 18 employee-side tax breakdown. federalWithholding is now FIT
  // alone — it used to absorb the placeholder flat tax. fica =
  // 6.2% Social Security (capped at SS wage base), medicare = 1.45% +
  // 0.9% surcharge over $200k YTD, stateWithholding = per-state SIT.
  federalWithholding Decimal           @db.Decimal(12, 2)
  fica               Decimal           @default(0) @db.Decimal(12, 2)
  medicare           Decimal           @default(0) @db.Decimal(12, 2)
  stateWithholding   Decimal           @default(0) @db.Decimal(12, 2)
  // Phase 18 employer-side. The company owes these on top of gross.
  employerFica       Decimal           @default(0) @db.Decimal(12, 2)
  employerMedicare   Decimal           @default(0) @db.Decimal(12, 2)
  employerFuta       Decimal           @default(0) @db.Decimal(12, 2)
  employerSuta       Decimal           @default(0) @db.Decimal(12, 2)
  // YTD snapshots at the moment this paystub was computed. Required for
  // SS-cap and Medicare-surcharge math; preserved for paystub display.
  ytdWages           Decimal           @default(0) @db.Decimal(12, 2)
  ytdMedicareWages   Decimal           @default(0) @db.Decimal(12, 2)
  netPay             Decimal           @db.Decimal(12, 2)
  // The state used for SIT lookup (snapshot of associate.state at compute
  // time). Lets the paystub label the SIT line and the auditor see why a
  // CA-rate was applied to someone who later moved to TX.
  taxState           String?
  status             PayrollItemStatus @default(PENDING)
  // sha256 of the rendered paystub PDF the FIRST time it was downloaded.
  // Subsequent downloads must produce the same hash; verifies immutability.
  paystubHash        String?
  // Stub for now; in production this is the Wise transfer ID or Branch txn ID.
  disbursementRef    String?
  disbursedAt        DateTime?         @db.Timestamptz(6)
  failureReason      String?
  payrollRun         PayrollRun        @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  associate          Associate         @relation(fields: [associateId], references: [id], onDelete: Restrict)
  createdAt          DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @db.Timestamptz(6)

  // Phase 22 — every disbursement call (success or fail) appends a row
  // here, even retries. PayrollItem.disbursementRef stores the latest
  // SUCCESS ref; this table preserves the full attempt history for audit.
  disbursementAttempts PayrollDisbursementAttempt[]

  // One paystub per (run, associate) — re-aggregating updates in place
  // rather than duplicating.
  @@unique([payrollRunId, associateId])
  @@index([associateId])
  @@index([status])
}

// Phase 22 — disbursement attempt log. One row per provider call, regardless
// of outcome. Lets finance reconstruct "who got paid when, by which provider,
// for which run" without trusting that PayrollItem.disbursementRef is
// authoritative (it isn't — retries overwrite it).
model PayrollDisbursementAttempt {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payrollItemId   String       @db.Uuid
  provider        String
  status          String       // SUCCESS | PENDING | FAILED (mirrors DisbursementResult.status)
  externalRef     String?
  failureReason   String?
  attemptedAt     DateTime     @default(now()) @db.Timestamptz(6)
  attemptedById   String?      @db.Uuid
  payrollItem     PayrollItem  @relation(fields: [payrollItemId], references: [id], onDelete: Cascade)
  attemptedBy     User?        @relation("PayrollDisbursementAttemptActor", fields: [attemptedById], references: [id], onDelete: SetNull)

  @@index([payrollItemId, attemptedAt])
  @@index([status])
}

model Candidate {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName      String
  lastName       String
  email          String         @unique
  phone          String?
  position       String?
  source         String?        // referral, indeed, careers-page, etc.
  stage          CandidateStage @default(APPLIED)
  notes          String?
  // When HIRED, populated with the new Associate's id (and clientId).
  hiredAssociateId String?      @unique @db.Uuid
  hiredClientId    String?      @db.Uuid
  hiredAt          DateTime?    @db.Timestamptz(6)
  rejectedReason   String?
  withdrawnReason  String?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt        DateTime?    @db.Timestamptz(6)

  @@index([stage])
  @@index([deletedAt])
}

model InviteToken {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // sha256(rawToken) — never store the raw token. The user-facing magic link
  // contains the raw token; the server hashes the lookup key before query.
  tokenHash   String    @unique
  userId      String    @db.Uuid
  expiresAt   DateTime  @db.Timestamptz(6)
  // Single-use: set on accept-invite. Lookups exclude consumedAt != NULL.
  consumedAt  DateTime? @db.Timestamptz(6)
  // Set the first time a reminder email goes out for this token. The 48h
  // sweep skips rows where this is non-null so users get reminded at most
  // once per token. HR-triggered resend always rotates the token (creates
  // a new row), so this never blocks a manual resend.
  reminderSentAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, consumedAt])
  @@index([expiresAt])
  // Sweep query filters by (consumedAt IS NULL, reminderSentAt IS NULL,
  // expiresAt > now, createdAt < threshold). Composite index covers it.
  @@index([consumedAt, reminderSentAt, createdAt])
}

model PerformanceReview {
  id             String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String                  @db.Uuid
  reviewerUserId String?                 @db.Uuid
  periodStart    DateTime                @db.Date
  periodEnd      DateTime                @db.Date
  overallRating  Int
  summary        String
  strengths      String?
  improvements   String?
  goals          String?
  status         PerformanceReviewStatus @default(DRAFT)
  submittedAt    DateTime?               @db.Timestamptz(6)
  acknowledgedAt DateTime?               @db.Timestamptz(6)
  associate      Associate               @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewer       User?                   @relation("PerformanceReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime                @updatedAt @db.Timestamptz(6)

  @@index([associateId, periodEnd])
  @@index([status])
}

model Notification {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  channel        NotificationChannel
  status         NotificationStatus  @default(QUEUED)
  // Recipient: a user (in-app), or by phone/email for SMS/EMAIL when the
  // recipient may not be a User yet.
  recipientUserId String?            @db.Uuid
  recipientPhone  String?
  recipientEmail  String?
  subject        String?
  body           String
  // Optional template/category so HR can filter ("shift_reminder", etc.).
  category       String?
  // Provider's id for the sent message (Twilio SID, FCM message id).
  externalRef    String?
  failureReason  String?
  sentAt         DateTime?           @db.Timestamptz(6)
  readAt         DateTime?           @db.Timestamptz(6)
  // Sender: HR user, or null for system-triggered notifications.
  senderUserId   String?             @db.Uuid
  recipientUser  User?               @relation("NotificationRecipient", fields: [recipientUserId], references: [id], onDelete: SetNull)
  senderUser     User?               @relation("NotificationSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now()) @db.Timestamptz(6)

  @@index([recipientUserId, createdAt])
  @@index([status])
  @@index([category])
}

model AuditLog {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorUserId  String?   @db.Uuid
  clientId     String?   @db.Uuid
  action       String
  entityType   String
  entityId     String
  metadata     Json?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  actorUser    User?     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([clientId])
  @@index([createdAt])
}
