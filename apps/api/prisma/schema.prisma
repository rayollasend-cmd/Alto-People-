// Alto People — Prisma schema (Phase 2)
// Conventions:
// - UUID primary keys (gen_random_uuid)
// - Timestamptz timestamps everywhere
// - deletedAt on PII / compliance-relevant tables (retention then delete)
// - Explicit onDelete on every relation
// - Denormalized clientId on documents/bg-checks/audit-log for future RLS
// - Money: Decimal(12,2). Encrypted PII: Bytes. Files: S3 keys, never blobs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =============================================================================
// Enums
// =============================================================================

enum Role {
  EXECUTIVE_CHAIRMAN
  HR_ADMINISTRATOR
  OPERATIONS_MANAGER
  LIVE_ASN
  ASSOCIATE
  CLIENT_PORTAL
  FINANCE_ACCOUNTANT
  INTERNAL_RECRUITER
  // Phase 76 — line manager. Has a small subset of HR power scoped to
  // their direct reports: approve their team's time entries / time-off /
  // schedule changes, view their team's performance reviews. Not a
  // replacement for OPERATIONS_MANAGER (which is org-wide ops admin).
  MANAGER
  // Workforce Manager — org-wide workforce planning + admin. Same
  // capability surface as HR_ADMINISTRATOR; distinct role label so audit
  // logs show who acted in which functional capacity.
  WORKFORCE_MANAGER
  // Marketing Manager — same admin surface as HR_ADMINISTRATOR; distinct
  // role label keeps audit attribution for marketing-driven actions.
  MARKETING_MANAGER
}

enum UserStatus {
  ACTIVE
  DISABLED
  INVITED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  PROSPECT
}

enum OnboardingTrack {
  STANDARD
  J1
  CLIENT_SPECIFIC
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  IN_REVIEW
  APPROVED
  REJECTED
}

enum TaskKind {
  PROFILE_INFO
  DOCUMENT_UPLOAD
  E_SIGN
  BACKGROUND_CHECK
  W4
  DIRECT_DEPOSIT
  POLICY_ACK
  J1_DOCS
  I9_VERIFICATION
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum DocumentKind {
  ID
  SSN_CARD
  I9_SUPPORTING
  W4_PDF
  OFFER_LETTER
  POLICY
  HOUSING_AGREEMENT
  TRANSPORT_AGREEMENT
  J1_DS2019
  J1_VISA
  // Phase 19 — server-rendered signed agreement PDF (typed-name e-sign).
  SIGNED_AGREEMENT
  // HR-uploaded result PDFs from external providers (Checkr, drug-test
  // lab, E-Verify). The associate-facing tasks collect the info; HR runs
  // the check externally and uploads the result here so everything lives
  // under one auditable Documents tab on the profile.
  BACKGROUND_CHECK_RESULT
  DRUG_TEST_RESULT
  I9_VERIFICATION_RESULT
  OTHER
}

enum DocumentStatus {
  UPLOADED
  VERIFIED
  REJECTED
  EXPIRED
}

enum BgCheckStatus {
  INITIATED
  IN_PROGRESS
  PASSED
  FAILED
  NEEDS_REVIEW
}

// Phase add-on — Walmart Contract Compliance Scorecard. Tags Course rows
// so the scorecard's training-completeness tile can count completions per
// regulatory category (EEO/harassment, OSHA safety, Walmart CADE, food
// handler) without scanning free-text titles.
enum ComplianceTag {
  EEO_HARASSMENT
  OSHA_SAFETY
  WALMART_CADE
  FOOD_HANDLER
}

// Phase add-on — E-Verify case state from the federal portal. HR records
// the case number + outcome after submitting Section 2 docs through the
// E-Verify website. PENDING covers cases that haven't returned a final
// status yet (TNC review window).
enum EVerifyStatus {
  PENDING
  EMPLOYMENT_AUTHORIZED
  TENTATIVE_NONCONFIRMATION
  FINAL_NONCONFIRMATION
  CLOSE_CASE_AND_RESUBMIT
}

enum PayoutType {
  BANK_ACCOUNT
  BRANCH_CARD
}

enum W4FilingStatus {
  SINGLE
  MARRIED_FILING_JOINTLY
  HEAD_OF_HOUSEHOLD
}

// Phase 41 — distinguishes W-2 employees (subject to W-4, FICA, Medicare,
// FUTA/SUTA, federal/state withholding) from 1099 contractors (paid gross,
// no withholding, no employer-side payroll tax). Drives onboarding
// checklist (1099s skip W-4) and payroll computation (1099 line items
// have all tax fields zeroed; gross == net).
enum EmploymentType {
  W2_EMPLOYEE
  CONTRACTOR_1099_INDIVIDUAL
  CONTRACTOR_1099_BUSINESS
}

enum I9DocumentList {
  LIST_A
  LIST_B_AND_C
}

// USCIS Form I-9 Section 1 citizenship attestation. The employee picks
// exactly one — Phase 20 self-attest endpoint enforces that.
enum I9CitizenshipStatus {
  US_CITIZEN
  NON_CITIZEN_NATIONAL
  LAWFUL_PERMANENT_RESIDENT
  ALIEN_AUTHORIZED_TO_WORK
}

enum TimeEntryStatus {
  ACTIVE // clocked in, not yet out
  COMPLETED // clocked out, awaiting review
  APPROVED // HR/Ops approved for payroll
  REJECTED // HR/Ops rejected (associate must edit + resubmit)
}

enum ShiftStatus {
  DRAFT // HR scratch pad, not yet open for assignment
  OPEN // published, no one assigned
  ASSIGNED // associate accepted (or HR assigned)
  COMPLETED // worked
  CANCELLED // pulled
}

enum PayrollRunStatus {
  DRAFT // newly created, items aggregated, can be edited
  FINALIZED // locked for review, ready to disburse
  DISBURSED // funds sent (real or stubbed)
  CANCELLED
}

enum PayrollItemStatus {
  PENDING // computed, not yet sent
  DISBURSED // sent (with disbursementRef)
  FAILED // disbursement attempt failed
  HELD // HR put a hold on this single item
}

// Wave 1.1 — Pay schedule cadence. Mirrors QuickBooks Online Payroll's four
// frequencies. Drives the run wizard's "next period" computation, the federal
// weekly OT split (>40h = 1.5x is week-bounded), and tax annualization
// multipliers (52 / 26 / 24 / 12) used by IRS Pub 15-T.
enum PayrollFrequency {
  WEEKLY
  BIWEEKLY
  SEMIMONTHLY
  MONTHLY
}

// Wave 1.2 — Earning line types on a paystub. Mirrors QuickBooks Online
// Payroll's "earnings" picker: each PayrollItem may have multiple earning
// lines that sum to grossPay. REGULAR + OVERTIME are auto-split from
// approved time entries (federal weekly rule: hours over 40 in a Mon–Sun
// week pay at 1.5x). The remaining kinds are manual entries the run-wizard
// surfaces as add-on lines.
enum PayrollEarningKind {
  REGULAR
  OVERTIME
  DOUBLE_TIME
  HOLIDAY
  SICK
  VACATION
  BONUS
  COMMISSION
  TIPS
  REIMBURSEMENT
}

enum NotificationChannel {
  SMS // Twilio (Phase 12 stubbed)
  PUSH // FCM (Phase 12 stubbed)
  EMAIL // SES / Resend (Phase 12 stubbed)
  IN_APP // delivered via the web inbox; no external service
}

enum NotificationStatus {
  QUEUED // accepted, not yet sent
  SENT // delivered to provider (or in-app written)
  FAILED // provider returned an error
  READ // IN_APP only — recipient opened it
}

enum PerformanceReviewStatus {
  DRAFT // HR is still composing — not visible to associate
  SUBMITTED // visible to associate, awaiting acknowledgement
  ACKNOWLEDGED // associate has read + signed off
}

enum CandidateStage {
  APPLIED // record exists, hasn't been screened yet
  SCREENING // recruiter is reviewing
  INTERVIEW // interview scheduled / in progress
  OFFER // offer extended, awaiting response
  HIRED // accepted; converted to Associate
  WITHDRAWN // candidate pulled out
  REJECTED // we passed
}

enum BreakType {
  MEAL // 30+ min unpaid (state-dependent)
  REST // 10-15 min paid
}

enum ShiftSwapStatus {
  PENDING_PEER // sent to counterparty associate
  PEER_ACCEPTED // counterparty agreed; awaiting manager approval
  PEER_DECLINED // counterparty refused
  MANAGER_APPROVED // executed — shift assignment swapped
  MANAGER_REJECTED // manager refused after peer accepted
  CANCELLED // requester pulled it
}

// Phase 78 — Position is a seat-in-the-org concept distinct from a
// person. A Position can be planned/open/filled/frozen/closed; only
// a FILLED position has a filledByAssociateId.
enum PositionStatus {
  PLANNED
  OPEN
  FILLED
  FROZEN
  CLOSED
}

// =============================================================================
// Models
// =============================================================================

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String     @unique
  passwordHash String?    @db.VarChar(255)
  role         Role
  status       UserStatus @default(INVITED)
  tokenVersion Int        @default(0)
  // IANA timezone preference for date display in /settings, login history,
  // and (later) email templates. Nullable — when null, the UI falls back
  // to the browser's locale, the email layer falls back to UTC.
  timezone     String?    @db.VarChar(64)
  associateId  String?    @unique @db.Uuid
  clientId     String?    @db.Uuid
  associate    Associate? @relation(fields: [associateId], references: [id], onDelete: SetNull)
  client       Client?    @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(6)
  deletedAt    DateTime?  @db.Timestamptz(6)

  signaturesGiven                   Signature[]                  @relation("UserSignatures")
  i9VerificationsAsRep              I9Verification[]             @relation("I9Verifier")
  auditLogActions                   AuditLog[]                   @relation("AuditActor")
  timeApprovals                     TimeEntry[]                  @relation("TimeApprover")
  createdShifts                     Shift[]                      @relation("ShiftCreator")
  createdPayrollRuns                PayrollRun[]                 @relation("PayrollRunCreator")
  verifiedDocuments                 DocumentRecord[]             @relation("DocumentVerifier")
  sentNotifications                 Notification[]               @relation("NotificationSender")
  receivedNotifications             Notification[]               @relation("NotificationRecipient")
  authoredReviews                   PerformanceReview[]          @relation("PerformanceReviewer")
  inviteTokens                      InviteToken[]
  passwordResetTokens               PasswordResetToken[]
  notificationPreferences           NotificationPreference[]
  emailChangeRequests               EmailChangeRequest[]
  createdEsignAgreements            EsignAgreement[]             @relation("EsignAgreementCreator")
  payrollDisbursementAttempts       PayrollDisbursementAttempt[] @relation("PayrollDisbursementAttemptActor")
  timeOffLedgerEntriesAuthored      TimeOffLedgerEntry[]
  timeOffReviews                    TimeOffRequest[]             @relation("TimeOffReviewer")
  associateHistoryEntries           AssociateHistory[]           @relation("AssociateHistoryActor")
  workflowDefinitions               WorkflowDefinition[]         @relation("WorkflowDefinitionCreator")
  reviewedLifeEvents                LifeEvent[]                  @relation("LifeEventReviewer")
  // Phase 83 — compensation back-relations.
  compRecordsActed                  CompensationRecord[]         @relation("CompRecordActor")
  meritProposalsProposed            MeritProposal[]              @relation("MeritProposalProposer")
  meritProposalsDecided             MeritProposal[]              @relation("MeritProposalDecider")
  // Phase 84 — performance back-relations.
  goalsCreated                      Goal[]                       @relation("GoalCreator")
  oneOnOnesAsManager                OneOnOne[]                   @relation("OneOnOneManager")
  kudosSent                         Kudo[]                       @relation("KudoSender")
  pipsAsManager                     Pip[]                        @relation("PipManager")
  reviews360Requested               Review360[]                  @relation("Review360Requester")
  reviews360FeedbackGiven           Review360Feedback[]          @relation("Review360FeedbackFrom")
  // Phase 85 — claim decisions.
  shiftClaimsDecided                OpenShiftClaim[]             @relation("OpenShiftClaimDecider")
  // Phase 86 — tip pool authorship.
  tipPoolsCreated                   TipPool[]                    @relation("TipPoolCreator")
  // Phase 87 — broadcast / survey authorship + receipts + responses.
  broadcastsCreated                 Broadcast[]                  @relation("BroadcastCreator")
  broadcastReceipts                 BroadcastReceipt[]           @relation("BroadcastReceiptUser")
  surveysCreated                    Survey[]                     @relation("SurveyCreator")
  surveyResponses                   SurveyResponse[]             @relation("SurveyRespondent")
  // Phase 88 — OSHA incident reporters.
  oshaIncidentsReported             OshaIncident[]               @relation("OshaIncidentReporter")
  // Phase 89 — document template authorship + renders.
  documentTemplatesCreated          DocumentTemplate[]           @relation("DocTemplateCreator")
  documentTemplateVersionsPublished DocumentTemplateVersion[]    @relation("DocTemplateVersionPublisher")
  documentsRendered                 DocumentRender[]             @relation("DocRenderer")
  // Phase 90 — recruiting authorship.
  interviewKitsCreated              InterviewKit[]               @relation("InterviewKitCreator")
  interviewsAsInterviewer           Interview[]                  @relation("Interviewer")
  offersCreated                     Offer[]                      @relation("OfferCreator")
  referralsMade                     Referral[]                   @relation("Referrer")
  jobPostingsCreated                JobPosting[]                 @relation("JobPostingCreator")
  // Phase 91 — garnishments + tax forms authorship.
  garnishmentsCreated               Garnishment[]                @relation("GarnishmentCreator")
  taxFormsFiled                     TaxForm[]                    @relation("TaxFormFiler")
  // Phase 92 — open enrollment + QLE authorship.
  openEnrollmentsCreated            OpenEnrollmentWindow[]       @relation("OpenEnrollmentCreator")
  qleDecisions                      QualifyingLifeEvent[]        @relation("QleDecider")
  // Phase 93 — API keys + webhooks authorship.
  apiKeysCreated                    ApiKey[]                     @relation("ApiKeyCreator")
  webhooksCreated                   Webhook[]                    @relation("WebhookCreator")
  // Phase 94 — LMS course authorship + enrollment assignment.
  coursesCreated                    Course[]                     @relation("CourseCreator")
  enrollmentsAssigned               CourseEnrollment[]           @relation("EnrollmentAssigner")
  // Phase 95 — worktag assignments authored.
  worktagAssignmentsAuthored        WorktagAssignment[]          @relation("WorktagAssigner")
  // Phase 96 — saved reports authored.
  reportsCreated                    Report[]                     @relation("ReportCreator")
  // Phase 97 — reimbursement decisions.
  reimbursementsDecided             Reimbursement[]              @relation("ReimbursementDecider")
  // Phase 99 — kiosk authorship (devices registered, PINs assigned).
  kioskDevicesCreated               KioskDevice[]                @relation("KioskDeviceCreator")
  kioskPinsCreated                  KioskPin[]                   @relation("KioskPinCreator")
  kioskPunchesReviewed              KioskPunch[]                 @relation("KioskPunchReviewer")
  assetAssignmentsAssigned          AssetAssignment[]            @relation("AssetAssigner")
  assetAssignmentsReturned          AssetAssignment[]            @relation("AssetReturner")
  pulseSurveysCreated               PulseSurvey[]                @relation("PulseSurveyCreator")
  associateSkillsVerified           AssociateSkill[]             @relation("AssociateSkillVerifier")
  mentorshipsProposed               Mentorship[]                 @relation("MentorshipProposer")
  learningPathsCreated              LearningPath[]               @relation("LearningPathCreator")
  successionCandidatesCreated       SuccessionCandidate[]
  probationsCreated                 ProbationPeriod[]            @relation("ProbationCreator")
  probationsDecided                 ProbationPeriod[]            @relation("ProbationDecider")
  holidaysCreated                   Holiday[]
  disciplinaryActionsIssued         DisciplinaryAction[]         @relation("DisciplineIssuer")
  disciplinaryActionsRescinded      DisciplinaryAction[]         @relation("DisciplineRescinder")
  separationsInitiated              Separation[]                 @relation("SeparationInitiator")
  separationsCompleted              Separation[]                 @relation("SeparationCompleter")
  exitInterviewsConducted           Separation[]                 @relation("SeparationExitInterviewer")
  internalApplicationsReviewed      InternalJobApplication[]     @relation("InternalApplicationReviewer")
  vaccinationRecordsCreated         VaccinationRecord[]
  agreementsIssued                  Agreement[]
  hrCasesAssigned                   HrCase[]
  hrCaseCommentsAuthored            HrCaseComment[]              @relation("HrCaseCommentUserAuthor")
  kbArticlesAuthored                KbArticle[]
  rampPlansCreated                  RampPlan[]                   @relation("RampPlanCreator")
  rampPlansManaged                  RampPlan[]                   @relation("RampPlanManager")
  careerLaddersCreated              CareerLadder[]
  tuitionRequestsReviewed           TuitionRequest[]             @relation("TuitionReviewer")
  tuitionRequestsPaid               TuitionRequest[]             @relation("TuitionPayer")
  anonymousReportsAssigned          AnonymousReport[]            @relation("AnonReportAssignee")
  anonymousReportUpdates            AnonymousReportUpdate[]      @relation("AnonReportAuthor")
  equityGrantsIssued                EquityGrant[]                @relation("EquityGrantedBy")
  volunteerEntriesReviewed          VolunteerEntry[]             @relation("VolunteerReviewer")

  @@index([role])
  @@index([clientId])
  @@index([deletedAt])
}

model Client {
  id                   String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  industry             String?
  status               ClientStatus @default(ACTIVE)
  contactEmail         String?
  // Two-letter USPS code of the work site. Drives Phase 23 OT/meal-break
  // policy AND Phase 25 predictive-scheduling enforcement (NY, IL, WA, PA,
  // OR demand 14-day notice). Null = federal default = no state-specific
  // rules enforced.
  state                String?      @db.VarChar(2)
  // Geofence anchor for clock-in validation. NULL latitude/longitude means
  // no geofence enforced (associates can clock in from anywhere).
  // Stored as Decimal for precision; ~5cm at 7 decimals.
  latitude             Decimal?     @db.Decimal(10, 7)
  longitude            Decimal?     @db.Decimal(10, 7)
  geofenceRadiusMeters Int?
  createdAt            DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @db.Timestamptz(6)
  deletedAt            DateTime?    @db.Timestamptz(6)

  applications           Application[]
  users                  User[]
  policies               Policy[]
  templates              OnboardingTemplate[]
  shifts                 Shift[]
  payrollRuns            PayrollRun[]
  // Wave 1.1 — Pay schedules scoped to this client.
  payrollSchedules       PayrollSchedule[]
  jobs                   Job[]
  benefitsPlans          BenefitsPlan[]
  quickbooksConnection   QuickbooksConnection?
  shiftTemplates         ShiftTemplate[]
  // Phase 76 — org hierarchy entities are per-client.
  departments            Department[]
  costCenters            CostCenter[]
  jobProfiles            JobProfile[]
  // Phase 78 — positions / seats.
  positions              Position[]
  // Phase 80 — workflow definitions can be client-scoped.
  workflows              WorkflowDefinition[]
  // Phase 81 — custom field definitions can be client-scoped.
  customFieldDefinitions CustomFieldDefinition[]
  // Phase 83 — compensation bands + merit cycles.
  compBands              CompBand[]
  meritCycles            MeritCycle[]
  // Phase 85 — qualifications catalog.
  qualifications         Qualification[]
  // Phase 117 — client-specific holidays.
  holidays               Holiday[]
  // Phase 124 — client-specific KB articles.
  kbArticles             KbArticle[]
  // Phase 126 — career ladders defined for this client.
  careerLadders          CareerLadder[]
  // Phase 130 — VTO policy override (one-per-client; NULL = global default).
  vtoPolicy              VtoPolicy?
  // Phase 86 — projects, premium-pay rules, tip pools.
  projects               Project[]
  premiumPayRules        PremiumPayRule[]
  tipPools               TipPool[]
  // Phase 87 — broadcasts + surveys (when client-scoped).
  broadcasts             Broadcast[]
  surveys                Survey[]
  // Phase 88 — OSHA incidents.
  oshaIncidents          OshaIncident[]
  // Phase 89 — document templates can be client-scoped.
  documentTemplates      DocumentTemplate[]
  // Phase 90 — recruiting catalog.
  interviewKits          InterviewKit[]
  offers                 Offer[]
  jobPostings            JobPosting[]
  // Phase 92 — open enrollment windows.
  openEnrollmentWindows  OpenEnrollmentWindow[]
  // Phase 93 — public API keys + outbound webhooks scoped to this client.
  apiKeys                ApiKey[]
  webhooks               Webhook[]
  // Phase 94 — LMS courses scoped to this client.
  courses                Course[]
  // Phase 99 — kiosk devices + PINs registered at this client.
  kioskDevices           KioskDevice[]
  kioskPins              KioskPin[]
  // Phase 109 — pulse surveys scoped to this client.
  pulseSurveys           PulseSurvey[]
  // Phase 114 — learning paths scoped to this client.
  learningPaths          LearningPath[]

  @@index([status])
  @@index([deletedAt])
}

model Associate {
  id                String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName         String
  lastName          String
  dob               DateTime?      @db.Date
  email             String         @unique
  phone             String?
  ssnLast4          String?        @db.VarChar(4)
  addressLine1      String?
  addressLine2      String?
  city              String?
  state             String?        @db.VarChar(2)
  zip               String?        @db.VarChar(10)
  j1Status          Boolean        @default(false)
  // Phase 41 — W-2 vs 1099. Default W2 keeps every existing record's
  // payroll math identical; 1099 records skip W-4 / FICA / Medicare.
  employmentType    EmploymentType @default(W2_EMPLOYEE)
  // Phase 76 — org hierarchy. All four are nullable: existing rows
  // continue to work with NULLs and HR fills them in over time. The
  // managerId self-reference enables direct-reports queries.
  managerId         String?        @db.Uuid
  departmentId      String?        @db.Uuid
  costCenterId      String?        @db.Uuid
  jobProfileId      String?        @db.Uuid
  // Wave 1.1 — pay schedule assignment. Drives the payroll run wizard's
  // "next period to run" calculation and determines pay frequency for
  // tax annualization. NULL = legacy associates that haven't been
  // assigned to a schedule yet (treated as biweekly default until set).
  payrollScheduleId String?        @db.Uuid
  // Wave 3.2 — QBO Employee.Id (W2) or Vendor.Id (1099) cache. Set the
  // first time we sync this associate to QuickBooks. Used as the dedup
  // key so we never create duplicate QBO records, and (future) as the
  // EmployeeRef on per-associate journal entries.
  qboEmployeeId     String?
  qboVendorId       String?
  qboSyncedAt       DateTime?      @db.Timestamptz(6)
  // Stamped when HR approves the associate's onboarding application
  // (POST /onboarding/applications/:id/approve). The date HR enters in
  // the approve dialog — distinct from Application.startDate (the
  // *planned* start at invitation time, which can differ if HR changes
  // their mind during review).
  hireDate          DateTime?      @db.Date
  // Profile photo. photoS3Key is the storage path under uploads/profile-photos/;
  // photoUpdatedAt is the cache-buster the API stamps onto the photo URL so
  // the browser refetches after an upload. Null when no photo on file —
  // Avatar then falls back to initials.
  photoS3Key        String?
  photoUpdatedAt    DateTime?      @db.Timestamptz(6)
  createdAt         DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime       @updatedAt @db.Timestamptz(6)
  deletedAt         DateTime?      @db.Timestamptz(6)

  user                    User?
  j1Profile               J1Profile?
  applications            Application[]
  documents               DocumentRecord[]
  signatures              Signature[]              @relation("AssociateSignatures")
  backgroundChecks        BackgroundCheck[]
  policyAcks              PolicyAcknowledgment[]
  i9Verification          I9Verification?
  w4Submission            W4Submission?
  payoutMethods           PayoutMethod[]
  timeEntries             TimeEntry[]
  assignedShifts          Shift[]
  payrollItems            PayrollItem[]
  performanceReviews      PerformanceReview[]
  availability            AssociateAvailability[]
  swapsRequested          ShiftSwapRequest[]       @relation("SwapRequester")
  swapsReceived           ShiftSwapRequest[]       @relation("SwapCounterparty")
  timeOffBalances         TimeOffBalance[]
  timeOffLedger           TimeOffLedgerEntry[]
  timeOffRequests         TimeOffRequest[]
  benefitsEnrollments     BenefitsEnrollment[]
  timeOffEntitlements     TimeOffEntitlement[]
  // Phase 76 — manager chain.
  manager                 Associate?               @relation("AssociateManager", fields: [managerId], references: [id], onDelete: SetNull)
  directReports           Associate[]              @relation("AssociateManager")
  department              Department?              @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  costCenter              CostCenter?              @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  jobProfile              JobProfile?              @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  payrollSchedule         PayrollSchedule?         @relation(fields: [payrollScheduleId], references: [id], onDelete: SetNull)
  // Phase 77 — effective-dated history of tracked fields.
  history                 AssociateHistory[]
  // Phase 78 — positions filled and managed.
  filledPositions         Position[]               @relation("PositionFilledBy")
  managedPositions        Position[]               @relation("PositionManager")
  // Phase 82 — self-service personal data.
  emergencyContacts       EmergencyContact[]
  dependents              Dependent[]
  beneficiaries           Beneficiary[]
  lifeEvents              LifeEvent[]
  taxDocuments            TaxDocument[]
  // Phase 83 — compensation history + merit-cycle proposals.
  compRecords             CompensationRecord[]
  meritProposals          MeritProposal[]
  // Phase 84 — performance: goals, 1:1s, kudos received, PIPs, 360s.
  goals                   Goal[]
  oneOnOnes               OneOnOne[]
  kudosReceived           Kudo[]                   @relation("KudoRecipient")
  pips                    Pip[]
  reviews360Subject       Review360[]              @relation("Review360Subject")
  // Phase 85 — qualifications + claimed open shifts.
  qualifications          AssociateQualification[]
  shiftClaims             OpenShiftClaim[]
  // Phase 86 — tip pool allocations.
  tipPoolAllocations      TipPoolAllocation[]
  // Phase 88 — OSHA incidents (subject) + EEO record (1:1).
  oshaIncidents           OshaIncident[]
  eeo                     AssociateEeo?
  // Phase 89 — document renders targeting this associate.
  documentRenders         DocumentRender[]
  // Phase 91 — garnishments + tax forms (W-2, 1099-NEC).
  garnishments            Garnishment[]
  taxForms                TaxForm[]
  // Phase 92 — qualifying life events, COBRA offers, ACA monthly snapshots.
  qles                    QualifyingLifeEvent[]
  cobraOffers             CobraOffer[]
  acaMonths               AcaMonth[]
  // Phase 94 — LMS course enrollments.
  courseEnrollments       CourseEnrollment[]
  // Phase 97 — reimbursement requests.
  reimbursements          Reimbursement[]
  // Phase 99 — kiosk PINs (one per client) + punch history.
  kioskPins               KioskPin[]
  kioskPunches            KioskPunch[]
  // Phase 101 — face descriptor for kiosk match-on-punch.
  kioskFaceReference      KioskFaceReference?
  // Phase 108 — physical asset assignments (laptops, badges, keys…).
  assetAssignments        AssetAssignment[]
  // Phase 111 — skills + competencies.
  skills                  AssociateSkill[]
  // Phase 112 — mentorship pairings.
  mentorshipsAsMentor     Mentorship[]             @relation("MentorshipMentor")
  mentorshipsAsMentee     Mentorship[]             @relation("MentorshipMentee")
  // Phase 114 — learning path enrollments.
