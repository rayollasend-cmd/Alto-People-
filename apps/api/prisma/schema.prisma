}

model I9Verification {
  id                         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId                String               @unique @db.Uuid
  section1CompletedAt        DateTime?            @db.Timestamptz(6)
  // Phase 20 — Section 1 employee self-attestation fields. citizenshipStatus
  // is the exclusive choice the employee picks. alienRegistrationNumberEnc
  // is encrypted at rest (same key as W-4 SSN); workAuthExpiresAt applies
  // only to ALIEN_AUTHORIZED_TO_WORK (or LAWFUL_PERMANENT_RESIDENT with an
  // expiring USCIS number). section1TypedName + IP + userAgent capture the
  // typed-name e-signature exactly per Phase 19's pattern.
  citizenshipStatus          I9CitizenshipStatus?
  alienRegistrationNumberEnc Bytes?
  workAuthExpiresAt          DateTime?            @db.Date
  section1TypedName          String?
  section1Ip                 String?
  section1UserAgent          String?
  // Set when the associate clicks "Submit for HR review" after signing
  // Section 1 and uploading documents. Distinct from section1CompletedAt:
  // a signed Section 1 with no documents is not yet ready for HR. Drives
  // the I9_VERIFICATION task transition PENDING → IN_PROGRESS so the
  // associate gets visible confirmation that the ball is in HR's court.
  documentsSubmittedAt       DateTime?            @db.Timestamptz(6)
  section2VerifierUserId     String?              @db.Uuid
  section2CompletedAt        DateTime?            @db.Timestamptz(6)
  documentList               I9DocumentList?
  supportingDocIds           Json?
  // Phase add-on — E-Verify (the federal portal HR runs separately after
  // Section 2). The case number is opaque (assigned by USCIS); status is
  // the rolled-up outcome. eVerifyClosedAt stamps when the case left
  // PENDING. Compliance scorecard's onboarding tile counts an associate
  // as fully E-Verified only when status = EMPLOYMENT_AUTHORIZED.
  eVerifyCaseNumber          String?
  eVerifyStatus              EVerifyStatus?
  eVerifyClosedAt            DateTime?            @db.Timestamptz(6)
  associate                  Associate            @relation(fields: [associateId], references: [id], onDelete: Cascade)
  section2Verifier           User?                @relation("I9Verifier", fields: [section2VerifierUserId], references: [id], onDelete: SetNull)
  createdAt                  DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt                  DateTime             @updatedAt @db.Timestamptz(6)
}

