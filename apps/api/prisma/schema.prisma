// Phase 99 — Kiosk-mode clock in/out: 4-digit PIN + selfie.

enum KioskPunchAction {
  CLOCK_IN
  CLOCK_OUT
  REJECTED
  // Phase 105 — break in/out from a kiosk. Tied to a BreakEntry whose
  // parent is the associate's open TimeEntry.
  BREAK_START
  BREAK_END
}

enum KioskPunchReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum KioskAnomalyKind {
  FACE_MISMATCH
  IMPOSSIBLE_TRAVEL
  GEOFENCE_NEAR_MISS
}

model KioskDevice {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId     String    @db.Uuid
  name         String
  tokenHash    String
  lastSeenAt   DateTime? @db.Timestamptz(6)
  isActive     Boolean   @default(true)
  // Phase 100 — optional geofence. All three set together or all NULL
  // (CHECK constraint). When set, punches must report coords within
  // radiusMeters or get rejected.
  latitude     Decimal?  @db.Decimal(10, 7)
  longitude    Decimal?  @db.Decimal(10, 7)
  radiusMeters Int?
  createdById  String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)

  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("KioskDeviceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  punches   KioskPunch[]

  @@index([clientId, isActive])
}

model KioskPin {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId  String   @db.Uuid
  clientId     String   @db.Uuid
  pinHmac      Bytes
  // Encrypted plaintext so the associate can see their own employee
  // number on /me/profile and HR can show it again in the directory.
  // Encryption uses the same AES-256-GCM helper as W4/payout secrets.
  pinEncrypted Bytes?
  createdById  String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  associate Associate    @relation(fields: [associateId], references: [id], onDelete: Cascade)
  client    Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?        @relation("KioskPinCreator", fields: [createdById], references: [id], onDelete: SetNull)
  punches   KioskPunch[]

  // One employee number per associate, unique across the entire company
  // (not just per client). 4 digits = 10,000 max — flag once we cross
  // ~80% to widen to 5+.
  @@unique([associateId])
  @@unique([pinHmac])
}

model KioskPunch {
  id              String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kioskDeviceId   String                  @db.Uuid
  kioskPinId      String?                 @db.Uuid
  associateId     String?                 @db.Uuid
  timeEntryId     String?                 @db.Uuid
  action          KioskPunchAction
  selfie          Bytes?
  rejectReason    String?
  // Phase 100 — coords reported by the kiosk + computed distance from
  // the device's geofence center. NULL when device has no geofence.
  punchLat        Decimal?                @db.Decimal(10, 7)
  punchLng        Decimal?                @db.Decimal(10, 7)
  distanceMeters  Int?
  // Phase 101 — face match telemetry. NULL when no descriptor was sent
  // (camera denied / models still loading). faceMismatch=true means the
  // distance exceeded the threshold; HR reviews — we don't auto-reject.
  faceDistance    Float?
  faceMismatch    Boolean?
  // Phase 102 — offline queue support. idempotencyKey dedupes retries
  // (unique partial index — NULL allowed for direct online punches that
  // skipped the queue). clientPunchedAt is the wall-clock time the user
  // pressed the button; used as TimeEntry.clockInAt/clockOutAt when
  // provided, so a punch queued at 8am and synced at 11am still logs 8am.
  idempotencyKey  String?                 @unique
  clientPunchedAt DateTime?               @db.Timestamptz(6)
  // Phase 103 — anomaly review queue. NULL = no review needed; PENDING
  // when a flag (face mismatch, impossible travel, etc.) was raised.
  // Approve leaves the TimeEntry intact; reject voids it.
  reviewStatus    KioskPunchReviewStatus?
  reviewedById    String?                 @db.Uuid
  reviewedAt      DateTime?               @db.Timestamptz(6)
  reviewNotes     String?
  // Phase 104 — discrete anomaly classification + free-form detail.
  // Captured at punch-write time so the review UI knows what raised the
  // flag (face mismatch, impossible travel, etc.) and can show context.
  anomalyKind     KioskAnomalyKind?
  anomalyDetail   String?
  createdAt       DateTime                @default(now()) @db.Timestamptz(6)

  device           KioskDevice          @relation(fields: [kioskDeviceId], references: [id], onDelete: Cascade)
  pin              KioskPin?            @relation(fields: [kioskPinId], references: [id], onDelete: SetNull)
  associate        Associate?           @relation(fields: [associateId], references: [id], onDelete: SetNull)
  timeEntry        TimeEntry?           @relation(fields: [timeEntryId], references: [id], onDelete: SetNull)
  reviewedBy       User?                @relation("KioskPunchReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  enrolledFaceRefs KioskFaceReference[] @relation("KioskFaceEnrolledByPunch")

  @@index([kioskDeviceId])
  @@index([associateId])
  @@index([createdAt])
}

// Phase 101 — One face descriptor per associate, captured on first
// successful kiosk punch (or HR-reset). 128-dim Float32 → 512 bytes.
model KioskFaceReference {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId       String   @unique @db.Uuid
  descriptor        Bytes
  enrolledByPunchId String?  @db.Uuid
  enrolledAt        DateTime @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @db.Timestamptz(6)

  associate       Associate   @relation(fields: [associateId], references: [id], onDelete: Cascade)
  enrolledByPunch KioskPunch? @relation("KioskFaceEnrolledByPunch", fields: [enrolledByPunchId], references: [id], onDelete: SetNull)
}

// Phase 108 — Employee asset tracking. Lifecycle: AVAILABLE -> ASSIGNED
// (via AssetAssignment) -> AVAILABLE (on return) -> RETIRED at end of
// life. AssetAssignment is the audit trail; "currently assigned" is the
// open row (returnedAt IS NULL).

enum AssetKind {
  LAPTOP
  PHONE
  TABLET
  BADGE
  KEY
  VEHICLE
  UNIFORM
  OTHER
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  RETIRED
  LOST
  IN_REPAIR
}

model Asset {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind          AssetKind
  label         String
  serial        String?
  model         String?
  status        AssetStatus @default(AVAILABLE)
  purchasedAt   DateTime?   @db.Date
  purchasePrice Decimal?    @db.Decimal(12, 2)
  notes         String?
  createdAt     DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @db.Timestamptz(6)

  assignments AssetAssignment[]

  @@index([status])
  @@index([kind])
}

model AssetAssignment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId      String    @db.Uuid
  associateId  String    @db.Uuid
  assignedAt   DateTime  @default(now()) @db.Timestamptz(6)
  assignedById String?   @db.Uuid
  returnedAt   DateTime? @db.Timestamptz(6)
  returnedById String?   @db.Uuid
  returnNotes  String?
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(6)

  asset      Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  associate  Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  assignedBy User?     @relation("AssetAssigner", fields: [assignedById], references: [id], onDelete: SetNull)
  returnedBy User?     @relation("AssetReturner", fields: [returnedById], references: [id], onDelete: SetNull)

  @@index([associateId])
}

// Phase 109 — Anonymous pulse surveys. PulseResponse intentionally
// has NO foreign key to User/Associate; the responderHash is HMAC
// of (userId, surveyId) so duplicates are blocked but identity is
// not recoverable from a DB dump alone.

enum PulseScale {
  SCORE_1_5
  YES_NO
}

enum PulseAudience {
  ALL
  BY_DEPARTMENT
  BY_CLIENT
}

model PulseSurvey {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  question             String
  scale                PulseScale
  audience             PulseAudience @default(ALL)
  audienceDepartmentId String?       @db.Uuid
  audienceClientId     String?       @db.Uuid
  openFrom             DateTime      @default(now()) @db.Timestamptz(6)
  openUntil            DateTime      @db.Timestamptz(6)
  createdById          String?       @db.Uuid
  createdAt            DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt            DateTime      @updatedAt @db.Timestamptz(6)

  audienceDepartment Department?     @relation(fields: [audienceDepartmentId], references: [id], onDelete: SetNull)
  audienceClient     Client?         @relation(fields: [audienceClientId], references: [id], onDelete: SetNull)
  createdBy          User?           @relation("PulseSurveyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  responses          PulseResponse[]

  @@index([openFrom, openUntil])
}

model PulseResponse {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  surveyId      String   @db.Uuid
  responderHash Bytes
  scoreValue    Int      @db.SmallInt
  comment       String?
  submittedAt   DateTime @default(now()) @db.Timestamptz(6)

  survey PulseSurvey @relation(fields: [surveyId], references: [id], onDelete: Cascade)

  @@unique([surveyId, responderHash])
  @@index([surveyId])
}

// Phase 111 — Skills & competencies. Skill is the catalog (Python,
// Forklift, Spanish, etc). AssociateSkill is the join with level +
// optional verification by a manager.

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

model Skill {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  category  String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  associateSkills         AssociateSkill[]
  // Phase 112 — mentorships focused on this skill.
  mentorships             Mentorship[]
  // Phase 126 — career-level skill requirements.
  careerLevelRequirements CareerLevelSkill[]

  @@index([category])
}

model AssociateSkill {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId     String     @db.Uuid
  skillId         String     @db.Uuid
  level           SkillLevel
  verifiedById    String?    @db.Uuid
  verifiedAt      DateTime?  @db.Timestamptz(6)
  yearsExperience Int?       @db.SmallInt
  notes           String?
  createdAt       DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime   @updatedAt @db.Timestamptz(6)

  associate  Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  skill      Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)
  verifiedBy User?     @relation("AssociateSkillVerifier", fields: [verifiedById], references: [id], onDelete: SetNull)

  @@unique([associateId, skillId])
  @@index([skillId])
  @@index([level])
}

// Phase 112 — Mentorship pairings. Directed: mentor teaches mentee.
// Optional focusSkillId ties into Phase 111 skills for "I want to
// grow at X" matching.

enum MentorshipStatus {
  PROPOSED
  ACTIVE
  COMPLETED
  DECLINED
  CANCELLED
}

model Mentorship {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mentorAssociateId String           @db.Uuid
  menteeAssociateId String           @db.Uuid
  focusSkillId      String?          @db.Uuid
  goals             String?
  status            MentorshipStatus @default(PROPOSED)
  startedAt         DateTime?        @db.Timestamptz(6)
  endedAt           DateTime?        @db.Timestamptz(6)
  endedReason       String?
  proposedById      String?          @db.Uuid
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @updatedAt @db.Timestamptz(6)

  mentor     Associate @relation("MentorshipMentor", fields: [mentorAssociateId], references: [id], onDelete: Cascade)
  mentee     Associate @relation("MentorshipMentee", fields: [menteeAssociateId], references: [id], onDelete: Cascade)
  focusSkill Skill?    @relation(fields: [focusSkillId], references: [id], onDelete: SetNull)
  proposedBy User?     @relation("MentorshipProposer", fields: [proposedById], references: [id], onDelete: SetNull)

  @@index([mentorAssociateId])
  @@index([menteeAssociateId])
  @@index([status])
}

// Phase 114 — Learning paths. Sequence Courses into ordered tracks.
// "Current step" = lowest-order step where the associate's
// CourseEnrollment isn't COMPLETED/WAIVED.

enum LearningPathStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LearningPathEnrollmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  WITHDRAWN
}

model LearningPath {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?            @db.Uuid
  title       String
  description String?
  isRequired  Boolean            @default(false)
  status      LearningPathStatus @default(DRAFT)
  createdById String?            @db.Uuid
  createdAt   DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime           @updatedAt @db.Timestamptz(6)
  deletedAt   DateTime?          @db.Timestamptz(6)

  client      Client?                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User?                    @relation("LearningPathCreator", fields: [createdById], references: [id], onDelete: SetNull)
  steps       LearningPathStep[]
  enrollments LearningPathEnrollment[]

  @@index([clientId, status])
}

model LearningPathStep {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pathId    String   @db.Uuid
  courseId  String   @db.Uuid
  order     Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  path   LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  course Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([pathId, courseId])
  @@unique([pathId, order])
}

model LearningPathEnrollment {
  id          String                       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pathId      String                       @db.Uuid
  associateId String                       @db.Uuid
  status      LearningPathEnrollmentStatus @default(ASSIGNED)
  assignedAt  DateTime                     @default(now()) @db.Timestamptz(6)
  completedAt DateTime?                    @db.Timestamptz(6)
  createdAt   DateTime                     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime                     @updatedAt @db.Timestamptz(6)

  path      LearningPath @relation(fields: [pathId], references: [id], onDelete: Cascade)
  associate Associate    @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([pathId, associateId])
  @@index([associateId])
}

// ===== Phase 115 — Succession planning =====================================
//
// Per-position bench. Each row designates an Associate as a successor for a
// Position with a readiness band. Forward-only data — readiness can be edited
// or the candidate removed. Listing the same person twice on a position is
// blocked by the unique index.
enum SuccessionReadiness {
  READY_NOW
  READY_1_2_YEARS
  READY_3_PLUS_YEARS
  EMERGENCY_COVER
}

model SuccessionCandidate {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  positionId  String              @db.Uuid
  associateId String              @db.Uuid
  readiness   SuccessionReadiness
  notes       String?
  createdById String?             @db.Uuid
  createdAt   DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime            @updatedAt @db.Timestamptz(6)

  position  Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([positionId, associateId])
  @@index([associateId])
  @@index([positionId])
}

// ===== Phase 116 — Probation period tracking ===============================
//
// One ACTIVE probation per associate at any time (partial unique index in the
// migration enforces it). Decisions are forward-only: ACTIVE → PASSED |
// EXTENDED (endDate moves forward, status returns to ACTIVE in a new row) |
// FAILED. The "extend" route closes the current row as EXTENDED and opens a
// new ACTIVE one with the new end date; the partial unique index makes the
// transaction safe.
enum ProbationStatus {
  ACTIVE
  PASSED
  EXTENDED
  FAILED
}

model ProbationPeriod {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId String          @db.Uuid
  startDate   DateTime        @db.Date
  endDate     DateTime        @db.Date
  status      ProbationStatus @default(ACTIVE)
  decision    String?
  decidedById String?         @db.Uuid
  decidedAt   DateTime?       @db.Timestamptz(6)
  createdById String?         @db.Uuid
  createdAt   DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @db.Timestamptz(6)

  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  decidedBy User?     @relation("ProbationDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  createdBy User?     @relation("ProbationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([endDate])
}

// ===== Phase 117 — Holiday calendar ========================================
//
// clientId NULL → company-wide. The unique index in the migration uses
// COALESCE on clientId so company-wide rows (NULL clientId) still
// de-duplicate against (date, name). Federal holidays are typically seeded
// company-wide; state holidays carry a 2-letter state code; client-specific
// holidays carry a clientId.
enum HolidayType {
  FEDERAL
  STATE
  COMPANY
  CLIENT_SPECIFIC
}

model Holiday {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?     @db.Uuid
  name        String
  date        DateTime    @db.Date
  type        HolidayType
  state       String?     @db.VarChar(2)
  paid        Boolean     @default(true)
  notes       String?
  createdById String?     @db.Uuid
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)

  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([clientId])
}

// ===== Phase 118 — Disciplinary action log =================================
//
// Distinct from Pip (which is a forward-looking improvement plan). This is
// the corrective record: each row is one incident on the formal warning
// ladder. Acknowledgment captures associate awareness; rescind unwinds an
// action that was issued in error or later overturned.
enum DisciplineKind {
  VERBAL_WARNING
  WRITTEN_WARNING
  FINAL_WARNING
  SUSPENSION
  TERMINATION
}

enum DisciplineStatus {
  ACTIVE
  ACKNOWLEDGED
  RESCINDED
}

model DisciplinaryAction {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId     String           @db.Uuid
  kind            DisciplineKind
  status          DisciplineStatus @default(ACTIVE)
  incidentDate    DateTime         @db.Date
  effectiveDate   DateTime         @db.Date
  suspensionDays  Int?
  description     String
  expectedAction  String?
  issuedById      String?          @db.Uuid
  acknowledgedAt  DateTime?        @db.Timestamptz(6)
  acknowledgedSig String?
  rescindedAt     DateTime?        @db.Timestamptz(6)
  rescindedReason String?
  rescindedById   String?          @db.Uuid
  createdAt       DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(6)

  associate   Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  issuedBy    User?     @relation("DisciplineIssuer", fields: [issuedById], references: [id], onDelete: SetNull)
  rescindedBy User?     @relation("DisciplineRescinder", fields: [rescindedById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([status])
  @@index([effectiveDate])
}

// ===== Phase 119 — Separations + exit interviews ===========================
//
// One in-flight separation per associate at a time (partial unique index in
// the migration). PLANNED is "we know they're leaving", IN_PROGRESS is "last
// day has come and we're processing", COMPLETE is "all done, off the books".
// Exit-interview fields can be filled at any point but typically during
// IN_PROGRESS. Re-hires get a brand new Separation row when they leave again.
enum SeparationReason {
  VOLUNTARY_OTHER_OPPORTUNITY
  VOLUNTARY_PERSONAL
  VOLUNTARY_RELOCATION
  VOLUNTARY_RETIREMENT
  INVOLUNTARY_PERFORMANCE
  INVOLUNTARY_LAYOFF
  INVOLUNTARY_MISCONDUCT
  END_OF_CONTRACT
  DECEASED
  OTHER
}

enum SeparationStatus {
  PLANNED
  IN_PROGRESS
  COMPLETE
}

model Separation {
  id                       String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId              String           @db.Uuid
  reason                   SeparationReason
  status                   SeparationStatus @default(PLANNED)
  noticeDate               DateTime?        @db.Date
  lastDayWorked            DateTime         @db.Date
  finalPaycheckDate        DateTime?        @db.Date
  rating                   Int?
  reasonNotes              String?
  feedbackPositive         String?
  feedbackImprovement      String?
  wouldRecommend           Boolean?
  wouldReturn              Boolean?
  exitInterviewCompletedAt DateTime?        @db.Timestamptz(6)
  exitInterviewByUserId    String?          @db.Uuid
  initiatedById            String?          @db.Uuid
  completedById            String?          @db.Uuid
  completedAt              DateTime?        @db.Timestamptz(6)
  createdAt                DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt                DateTime         @updatedAt @db.Timestamptz(6)

  associate       Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  initiatedBy     User?     @relation("SeparationInitiator", fields: [initiatedById], references: [id], onDelete: SetNull)
  completedBy     User?     @relation("SeparationCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  exitInterviewBy User?     @relation("SeparationExitInterviewer", fields: [exitInterviewByUserId], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([status])
  @@index([lastDayWorked])
}

// ===== Phase 120 — Internal mobility =======================================
//
// Lets current associates apply to internal JobPostings. Distinct from
// external Candidate-driven recruiting (Phase 25/90) — these applicants are
// already in the workforce. Reviewer marches the row through the funnel via
// status updates; (postingId, associateId) is unique so an associate can't
// double-apply to the same posting without withdrawing first.
enum InternalApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

model InternalJobApplication {
  id            String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postingId     String                    @db.Uuid
  associateId   String                    @db.Uuid
  status        InternalApplicationStatus @default(SUBMITTED)
  coverLetter   String?
  resumeUrl     String?
  reviewerNotes String?
  reviewedById  String?                   @db.Uuid
  reviewedAt    DateTime?                 @db.Timestamptz(6)
  createdAt     DateTime                  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime                  @updatedAt @db.Timestamptz(6)

  posting    JobPosting @relation(fields: [postingId], references: [id], onDelete: Cascade)
  associate  Associate  @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewedBy User?      @relation("InternalApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@unique([postingId, associateId])
  @@index([associateId])
  @@index([postingId, status])
}

// ===== Phase 121 — Vaccination + medical records ===========================
//
// Each row is one shot or test. Multi-dose vaccines (Hep B, COVID) get one
// row per dose with doseNumber and totalDoses to track completion.
// expiresOn drives the expirations dashboard for renewals (TB tests, flu).
enum VaccinationKind {
  COVID19
  INFLUENZA_FLU
  HEPATITIS_B
  TDAP
  MMR
  TB_TEST
  OTHER
}

model VaccinationRecord {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String          @db.Uuid
  kind           VaccinationKind
  customLabel    String?
  doseNumber     Int             @default(1)
  totalDoses     Int?
  administeredOn DateTime        @db.Date
  administeredBy String?
  manufacturer   String?
  lotNumber      String?
  documentUrl    String?
  expiresOn      DateTime?       @db.Date
  notes          String?
  createdById    String?         @db.Uuid
  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)

  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  createdBy User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([kind])
  @@index([expiresOn])
}

// ===== Phase 122 — Per-associate legal agreements ==========================
//
// One-off agreements (NDA, non-compete, IP assignment, arbitration, equity
// grants) that are signed by the individual associate. Distinct from
// PolicyAck (company-wide policies). supersedesId points at an older
// agreement the new one replaces — useful when an NDA is updated mid-tenure.
enum AgreementKind {
  NDA
  NON_COMPETE
  IP_ASSIGNMENT
  ARBITRATION
  EMPLOYMENT_OFFER
  SEPARATION_AGREEMENT
  EQUITY_GRANT
  OTHER
}

enum AgreementStatus {
  PENDING_SIGNATURE
  SIGNED
  EXPIRED
  SUPERSEDED
}

model Agreement {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId   String          @db.Uuid
  kind          AgreementKind
  customLabel   String?
  status        AgreementStatus @default(PENDING_SIGNATURE)
  documentUrl   String?
  effectiveDate DateTime?       @db.Date
  expiresOn     DateTime?       @db.Date
  signedAt      DateTime?       @db.Timestamptz(6)
  signature     String?
  supersedesId  String?         @db.Uuid
  notes         String?
  issuedById    String?         @db.Uuid
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(6)

  associate    Associate   @relation(fields: [associateId], references: [id], onDelete: Cascade)
  supersedes   Agreement?  @relation("AgreementSupersedes", fields: [supersedesId], references: [id], onDelete: SetNull)
  supersededBy Agreement[] @relation("AgreementSupersedes")
  issuedBy     User?       @relation(fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([status])
  @@index([expiresOn])
}

// ===== Phase 123 — HR cases (ticketing) =====================================
//
// Associates file cases against HR — benefits questions, payroll discrepancies,
// workplace concerns, etc. HR routes via assignedToId, advances status, leaves
// public replies and internalNote breadcrumbs (hidden from the associate). The
// model deliberately distinguishes user-author vs associate-author so HR
// replies and associate replies can both be threaded into the same comment
// stream without identity confusion.
enum CaseCategory {
  BENEFITS
  PAYROLL
  TIME_OFF
  PERSONAL_INFO
  WORKPLACE_CONCERN
  HARASSMENT
  PERFORMANCE
  OTHER
}

enum CasePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  WAITING_ASSOCIATE
  RESOLVED
  CLOSED
}

model HrCase {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId  String       @db.Uuid
  category     CaseCategory
  subject      String
  description  String
  priority     CasePriority @default(MEDIUM)
  status       CaseStatus   @default(OPEN)
  assignedToId String?      @db.Uuid
  resolvedAt   DateTime?    @db.Timestamptz(6)
  resolution   String?
  createdAt    DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @db.Timestamptz(6)

  associate  Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)
  assignedTo User?           @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  comments   HrCaseComment[]

  @@index([associateId])
  @@index([status])
  @@index([category])
  @@index([assignedToId])
}

model HrCaseComment {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId            String   @db.Uuid
  authorUserId      String?  @db.Uuid
  authorAssociateId String?  @db.Uuid
  body              String
  internalNote      Boolean  @default(false)
  createdAt         DateTime @default(now()) @db.Timestamptz(6)

  case            HrCase     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorUser      User?      @relation("HrCaseCommentUserAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  authorAssociate Associate? @relation("HrCaseCommentAssociateAuthor", fields: [authorAssociateId], references: [id], onDelete: SetNull)

  @@index([caseId])
}

// ===== Phase 124 — Knowledge base / FAQ ===================================
//
// Per-client OR company-wide (clientId NULL) self-service articles.
// View counts and helpful/notHelpful tallies are denormalized on the
// row and updated via dedicated endpoints to dodge contention. KbFeedback
// is the per-associate vote — unique on (articleId, associateId) so each
// person can vote at most once.
enum KbStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model KbArticle {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?   @db.Uuid
  title       String
  slug        String
  body        String
  category    String
  tags        String[]  @default([])
  status      KbStatus  @default(DRAFT)
  views       Int       @default(0)
  helpful     Int       @default(0)
  notHelpful  Int       @default(0)
  publishedAt DateTime? @db.Timestamptz(6)
  authorId    String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  client   Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author   User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  feedback KbFeedback[]

  @@index([status])
  @@index([category])
}

model KbFeedback {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  articleId   String   @db.Uuid
  associateId String   @db.Uuid
  helpful     Boolean
  comment     String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  article   KbArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  associate Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)

  @@unique([articleId, associateId])
  @@index([articleId])
}

// ===== Phase 125 — New-hire ramp plans (30/60/90) ==========================
//
// One ACTIVE ramp per associate at a time (partial unique index in the
// migration treats archivedAt IS NULL as "active"). Each plan has many
// RampMilestones at different day checkpoints (commonly 30, 60, 90, 180).
// Manager nudges status as the new hire progresses.
enum RampMilestoneStatus {
  PENDING
  ON_TRACK
  ACHIEVED
  MISSED
}

model RampPlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId String    @db.Uuid
  startDate   DateTime  @db.Date
  managerId   String?   @db.Uuid
  notes       String?
  archivedAt  DateTime? @db.Timestamptz(6)
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  associate  Associate       @relation(fields: [associateId], references: [id], onDelete: Cascade)
  manager    User?           @relation("RampPlanManager", fields: [managerId], references: [id], onDelete: SetNull)
  createdBy  User?           @relation("RampPlanCreator", fields: [createdById], references: [id], onDelete: SetNull)
  milestones RampMilestone[]

  @@index([associateId])
}

model RampMilestone {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId        String              @db.Uuid
  dayCheckpoint Int
  title         String
  description   String?
  status        RampMilestoneStatus @default(PENDING)
  achievedAt    DateTime?           @db.Timestamptz(6)
  notes         String?
  createdAt     DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime            @updatedAt @db.Timestamptz(6)

  plan RampPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, dayCheckpoint])
}

// ===== Phase 126 — Career ladders ==========================================
//
// CareerLadder is one progression path (typically per family — Engineering,
// Sales, Operations…). CareerLevel rows are the rungs, ranked 1..N inside the
// ladder (unique). Each rung optionally links a JobProfile and lists required
// skills with a minimum SkillLevel from Phase 111.
model CareerLadder {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clientId    String?   @db.Uuid
  name        String
  family      String?
  description String?
  archivedAt  DateTime? @db.Timestamptz(6)
  createdById String?   @db.Uuid
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  client    Client?       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  levels    CareerLevel[]

  @@index([clientId])
}

model CareerLevel {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ladderId     String   @db.Uuid
  rank         Int
  title        String
  description  String?
  jobProfileId String?  @db.Uuid
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  ladder     CareerLadder       @relation(fields: [ladderId], references: [id], onDelete: Cascade)
  jobProfile JobProfile?        @relation(fields: [jobProfileId], references: [id], onDelete: SetNull)
  skills     CareerLevelSkill[]

  @@unique([ladderId, rank])
  @@index([jobProfileId])
}

model CareerLevelSkill {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levelId   String     @db.Uuid
  skillId   String     @db.Uuid
  minLevel  SkillLevel
  createdAt DateTime   @default(now()) @db.Timestamptz(6)

  level CareerLevel @relation(fields: [levelId], references: [id], onDelete: Cascade)
  skill Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([levelId, skillId])
}

// ===== Phase 127 — Tuition reimbursement ===================================
//
// Per-course request flow. Associate submits with a receipt; after the term
// ends, attaches their grade. HR approves or rejects; once approved, a
// payroll process marks PAID. Distinct from Phase 97 reimbursements (general
// expenses) because tuition has IRS Section 127 reporting needs.
enum TuitionStatus {
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

model TuitionRequest {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId   String        @db.Uuid
  schoolName    String
  programName   String?
  courseName    String
  termStartDate DateTime      @db.Date
  termEndDate   DateTime      @db.Date
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD") @db.VarChar(3)
  status        TuitionStatus @default(SUBMITTED)
  receiptUrl    String?
  gradeReceived String?
  reviewedById  String?       @db.Uuid
  reviewedAt    DateTime?     @db.Timestamptz(6)
  reviewerNotes String?
  paidAt        DateTime?     @db.Timestamptz(6)
  paidById      String?       @db.Uuid
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(6)

  associate  Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("TuitionReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  paidBy     User?     @relation("TuitionPayer", fields: [paidById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([status])
}

enum ReportCategory {
  HARASSMENT
  DISCRIMINATION
  ETHICS_VIOLATION
  FRAUD
  SAFETY
  RETALIATION
  OTHER
}

enum ReportStatus {
  RECEIVED
  TRIAGING
  INVESTIGATING
  RESOLVED
  CLOSED
}

model AnonymousReport {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackingCode String         @unique
  category     ReportCategory
  subject      String
  description  String
  status       ReportStatus   @default(RECEIVED)
  contactEmail String?
  assignedToId String?        @db.Uuid
  resolution   String?
  resolvedAt   DateTime?      @db.Timestamptz(6)
  createdAt    DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime       @updatedAt @db.Timestamptz(6)

  assignedTo User?                   @relation("AnonReportAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  updates    AnonymousReportUpdate[]

  @@index([status])
  @@index([category])
}

model AnonymousReportUpdate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId       String   @db.Uuid
  body           String
  authorUserId   String?  @db.Uuid
  isFromReporter Boolean  @default(false)
  internalOnly   Boolean  @default(false)
  createdAt      DateTime @default(now()) @db.Timestamptz(6)

  report     AnonymousReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  authorUser User?           @relation("AnonReportAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([reportId])
}

enum EquityGrantType {
  RSU
  NSO
  ISO
  PHANTOM
  PERFORMANCE_RSU
}

enum EquityGrantStatus {
  PROPOSED
  GRANTED
  CANCELLED
  EXERCISED
  EXPIRED
}

model EquityGrant {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId      String            @db.Uuid
  grantType        EquityGrantType
  status           EquityGrantStatus @default(PROPOSED)
  totalShares      Int
  strikePrice      Decimal?          @db.Decimal(12, 4)
  currency         String            @default("USD") @db.VarChar(3)
  grantDate        DateTime          @db.Date
  vestingStartDate DateTime          @db.Date
  cliffMonths      Int               @default(12)
  vestingMonths    Int               @default(48)
  expirationDate   DateTime?         @db.Date
  notes            String?
  grantedById      String?           @db.Uuid
  createdAt        DateTime          @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @db.Timestamptz(6)

  associate     Associate            @relation(fields: [associateId], references: [id], onDelete: Cascade)
  grantedBy     User?                @relation("EquityGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)
  vestingEvents EquityVestingEvent[]

  @@index([associateId])
  @@index([status])
}

model EquityVestingEvent {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  grantId    String   @db.Uuid
  eventIndex Int
  vestDate   DateTime @db.Date
  shares     Int
  isCliff    Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  grant EquityGrant @relation(fields: [grantId], references: [id], onDelete: Cascade)

  @@unique([grantId, eventIndex])
  @@index([grantId])
  @@index([vestDate])
}

enum VtoStatus {
  PENDING
  APPROVED
  REJECTED
  MATCHED
}

model VolunteerEntry {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  associateId    String    @db.Uuid
  activityDate   DateTime  @db.Date
  hours          Decimal   @db.Decimal(5, 2)
  organization   String
  cause          String?
  description    String
  evidenceUrl    String?
  matchRequested Boolean   @default(false)
  matchAmount    Decimal?  @db.Decimal(10, 2)
  matchCurrency  String    @default("USD") @db.VarChar(3)
  status         VtoStatus @default(PENDING)
  reviewedById   String?   @db.Uuid
  reviewedAt     DateTime? @db.Timestamptz(6)
  reviewerNotes  String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  associate  Associate @relation(fields: [associateId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("VolunteerReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([associateId])
  @@index([status])
  @@index([activityDate])
