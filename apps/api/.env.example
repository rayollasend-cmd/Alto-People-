PORT=3001
CORS_ORIGIN=http://localhost:5173

# Local Docker Compose default
DATABASE_URL=postgresql://alto:alto_dev@localhost:5432/alto_people?schema=public

# DIRECT_URL is only needed when DATABASE_URL goes through a connection pooler
# (e.g. Neon's `-pooler` host or Supabase pooled URL). Prisma migrate cannot
# run through PgBouncer in transaction mode. For Docker Compose / direct
# Postgres, leave DIRECT_URL unset and Prisma will use DATABASE_URL.
# DIRECT_URL=postgresql://...

# Auth (Phase 3). Generate via: openssl rand -base64 48
# Must be >= 32 chars. Rotate for production.
JWT_SECRET=replace-me-with-output-of-openssl-rand-base64-48
JWT_TTL_SECONDS=86400

# Phase 4: at-rest encryption for PayoutMethod / W-4 SSN.
# 32 bytes base64. Generate via: openssl rand -base64 32
# Plaintext rows live in v=1 envelope; Phase 6 KMS adds v=2 additively.
PAYOUT_ENCRYPTION_KEY=replace-me-with-output-of-openssl-rand-base64-32

# Independent key for TOTP secret encryption. Optional — falls back to
# PAYOUT_ENCRYPTION_KEY when unset. Production should set this so MFA
# secrets can be rotated without re-encrypting every payout method.
# MFA_SECRET_ENCRYPTION_KEY=replace-me-with-output-of-openssl-rand-base64-32

# Ping the DB every N seconds so Neon's serverless compute doesn't suspend
# mid-session. Defaults to 0 (off) everywhere — production runs Neon with
# auto-suspend disabled at the branch level, so pings would just burn
# compute hours for no upside. Set to e.g. 240 to opt in if you're on a
# Neon tier (or branch) that suspends idle compute.
KEEP_ALIVE_INTERVAL_SECONDS=0

# ASN Nexus — separate Walmart-shift compliance app (Replit). When both
# vars are set, the /compliance scorecard's Tile 3 (Shift compliance)
# pulls live metrics (fill rate, no-show, MOD sign-off, temp logs,
# Fieldglass timesheets) from there. Unset = degraded fallback that
# only computes fill-rate from our local Shift table.
# ASN_NEXUS_BASE_URL=https://asn-nexus.replit.app
# ASN_NEXUS_API_KEY=asn_xxxxxxxxxxxxxxxxxxxxxxxx

# Phase 9 storage — overrides apps/api/uploads/ so a Railway Volume (or
# any mounted disk) can hold document blobs and profile photos across
# redeploys. REQUIRED on Railway: every upload lands in the container
# filesystem and is lost on redeploy without this. See apps/api/STORAGE.md
# for the dashboard volume-mount steps.
# UPLOAD_DIR=/data/uploads

# Base URL the magic links in invite / password-reset emails point to.
# Local dev: the Vite dev server. Production: the deployed web origin
# (e.g. https://people.altohr.com). Without this, "Reset password" links
# default to http://localhost:5173 and are useless to the recipient.
APP_BASE_URL=http://localhost:5173

# Resend transactional email — used for invite emails, password-reset
# magic links, and onboarding nudges. Both keys must be set together for
# real sending; if either is unset, the API logs the email body to the
# console (handy for local dev — you can copy the magic link from there).
#
# Setup:
#   1. Sign up at https://resend.com (free tier: 100 emails/day, 3k/mo)
#   2. Add and verify a sending domain (e.g. altohr.com) — Resend gives
#      you DNS records to publish; for first tests you can use the
#      shared "onboarding@resend.dev" sender without a verified domain.
#   3. Create an API key under https://resend.com/api-keys
#   4. RESEND_FROM should be a real address on the verified domain,
#      e.g. "Alto HR <hr@altohr.com>" — the human-friendly name in
#      angle brackets is shown by mail clients as the sender.
RESEND_API_KEY=
RESEND_FROM=
