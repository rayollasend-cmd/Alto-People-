# Test environment for `npm test` (vitest).
# Copy this file to `apps/api/.env.test` and edit the URLs.
#
# The integration tests run against a SEPARATE Postgres schema (`alto_test`)
# so dev data in `public` (or wherever your DATABASE_URL points) is never
# touched. Tables in `alto_test` are TRUNCATEd between every test.

NODE_ENV=test

# Same DB host as dev, but `schema=alto_test`. Migrations and the Prisma
# client both honor this, so all writes land in alto_test.*.
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DB?sslmode=require&schema=alto_test
DIRECT_URL=postgresql://USER:PASS@HOST:5432/DB?sslmode=require&schema=alto_test

# Fixed test secrets. Never reuse outside tests.
JWT_SECRET=test-jwt-secret-do-not-use-outside-tests-padding-pad-pad
JWT_TTL_SECONDS=3600
PAYOUT_ENCRYPTION_KEY=AQIDBAUGBwgJCgsMDQ4PEBESExQVFhcYGRobHB0eHyA=

# Force the email layer into stubbed mode for tests. WITHOUT these explicit
# blanks, `apps/api/.env` (where the developer has a real RESEND_API_KEY)
# leaks through after .env.test is loaded — dotenv doesn't override an
# already-defined key when the new file lacks it. With Resend "live" during
# tests we'd ping their API for every invite, eat the developer's quota,
# and break the dev-stub branch (`inviteUrl: ... ? null : acceptUrl`) that
# the invite tests rely on to extract the magic link.
RESEND_API_KEY=
RESEND_FROM=
APP_BASE_URL=http://localhost:5173
