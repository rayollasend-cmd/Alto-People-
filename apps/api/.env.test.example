# Test environment for `npm test` (vitest).
# Copy this file to `apps/api/.env.test` and edit the URLs.
#
# The integration tests run against a SEPARATE Postgres schema (`alto_test`)
# so dev data in `public` (or wherever your DATABASE_URL points) is never
# touched. Tables in `alto_test` are TRUNCATEd between every test.

NODE_ENV=test

# ── RECOMMENDED: local Postgres ────────────────────────────────────────────
# Run the suite against a Postgres on YOUR machine, not remote Neon. The
# full API suite drops from 25-40 minutes (and random "Can't reach database
# server" flakes when Neon's compute is waking) to a couple of minutes.
#
#   Option A — native install (Windows installer / brew / apt). One-time
#   role + db setup as the postgres superuser:
#     CREATE ROLE alto LOGIN PASSWORD 'alto_dev' CREATEDB;
#     CREATE DATABASE alto_people OWNER alto;
#
#   Option B — docker compose (repo root): `npm run db:up`
#     (creates the same alto/alto_dev/alto_people automatically)
#
DATABASE_URL=postgresql://alto:alto_dev@localhost:5432/alto_people?schema=alto_test
DIRECT_URL=postgresql://alto:alto_dev@localhost:5432/alto_people?schema=alto_test

# ── ALTERNATIVE: shared Neon dev branch ────────────────────────────────────
# Works, but slow (every query is a WAN round-trip) and the compute
# auto-suspends. Concurrent runs are serialized by an advisory lock in
# test/globalSetup.ts either way.
# DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require&schema=alto_test
# DIRECT_URL=postgresql://USER:PASS@HOST/DB?sslmode=require&schema=alto_test

# Fixed test secrets. Never reuse outside tests.
JWT_SECRET=test-jwt-secret-do-not-use-outside-tests-padding-pad-pad
JWT_TTL_SECONDS=3600
PAYOUT_ENCRYPTION_KEY=AQIDBAUGBwgJCgsMDQ4PEBESExQVFhcYGRobHB0eHyA=

# Force the email layer into stubbed mode for tests. Without these explicit
# blanks, a real RESEND_API_KEY from apps/api/.env leaks through (dotenv
# doesn't unset keys missing from the second file) and tests would send
# real email.
RESEND_API_KEY=
RESEND_FROM=
APP_BASE_URL=http://localhost:5173
