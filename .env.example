# Root .env.example — used by docker-compose for the local Postgres container.
# Copy to `.env` (gitignored) before running `npm run db:up`.

POSTGRES_USER=alto
POSTGRES_PASSWORD=alto_dev
POSTGRES_DB=alto_people

# Each app also loads its own env. See:
#   apps/api/.env.example   (API server + DATABASE_URL)
# The web app reads VITE_-prefixed vars from apps/web/.env (none required yet).
